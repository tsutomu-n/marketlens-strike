#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

run_step() {
  echo "==> $*"
  "$@"
}

uv sync --dev --locked
run_step uv run python -V
run_step uv run ruff check .
run_step uv run ruff format --check .
run_step uv run python scripts/check_current_docs.py
run_step uv run pyrefly check
run_step uv run ty check src --python-version 3.13 --output-format concise
run_step uv run pytest -q
