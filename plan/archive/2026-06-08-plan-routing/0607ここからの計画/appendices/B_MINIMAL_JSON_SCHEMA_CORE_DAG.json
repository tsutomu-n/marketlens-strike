{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core_dag.v1.schema.json",
  "title": "Core DAG v1",
  "type": "object",
  "required": [
    "schema_version",
    "dag_id",
    "name",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "const": "core_dag.v1"
    },
    "dag_id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "scope_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "treatment_candidate",
              "outcome",
              "confounder",
              "mediator",
              "moderator",
              "modeled_latent",
              "observed_proxy",
              "selection_mechanism",
              "data_quality",
              "neutralizer"
            ]
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "forbidden_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "reason"
        ],
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1
          },
          "to": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
