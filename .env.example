# Python
SIS_DATA_DIR=./data
SIS_LOG_LEVEL=INFO

# Research
SIS_DEFAULT_TIMEFRAMES=4h,1d,3d
FRED_API_KEY=

# Bitget demo read-only/local smoke.
# Use demo API credentials only. Do not put production Bitget credentials here.
BITGET_DEMO_API_KEY=
BITGET_DEMO_API_SECRET=
BITGET_DEMO_PASSPHRASE=

# Trade[XYZ] read-only execution state collector.
# Public user address only; no wallet secret, signing, live order, or exchange write.
SIS_TRADE_XYZ_EXECUTION_STATE_USER_ADDRESS=
SIS_TRADE_XYZ_EXECUTION_STATE_COLLECTOR_ENABLED=0

# Trade[XYZ] live write credentials are intentionally not defined here.
# Use local-only secrets only after the manual micro-live preflight is documented and approved.

# Alpaca real-market smoke
# Preferred names used by Alpaca docs.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Alternative names also accepted by the provider.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
SIS_ALPACA_API_KEY=
SIS_ALPACA_SECRET_KEY=
