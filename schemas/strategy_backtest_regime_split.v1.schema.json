{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_regime_split.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "split_kind",
    "source_backtest_metrics_path",
    "source_backtest_metrics_hash",
    "dimension_count",
    "summary",
    "dimensions",
    "dependency_added",
    "paper_only",
    "live_order_submitted",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used"
  ],
  "properties": {
    "schema_version": {"const": "strategy_backtest_regime_split.v1"},
    "created_at": {"type": "string"},
    "split_kind": {"const": "regime_dimension"},
    "source_backtest_metrics_path": {"type": "string"},
    "source_backtest_metrics_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "dimension_count": {"type": "integer", "minimum": 1},
    "summary": {
      "type": "object",
      "required": [
        "return_count",
        "dimension_count",
        "worst_dimension_id",
        "worst_bucket_id",
        "worst_bucket_total_return"
      ],
      "properties": {
        "return_count": {"type": "integer", "minimum": 0},
        "dimension_count": {"type": "integer", "minimum": 1},
        "worst_dimension_id": {"type": ["string", "null"]},
        "worst_bucket_id": {"type": ["string", "null"]},
        "worst_bucket_total_return": {"type": ["number", "null"]}
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension_id", "bucket_count", "buckets"],
        "properties": {
          "dimension_id": {"type": "string"},
          "bucket_count": {"type": "integer", "minimum": 0},
          "buckets": {
            "type": "array",
            "items": {"$ref": "#/$defs/bucket"}
          }
        },
        "additionalProperties": false
      }
    },
    "dependency_added": {"const": false},
    "paper_only": {"const": true},
    "live_order_submitted": {"const": false},
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false}
  },
  "additionalProperties": false,
  "$defs": {
    "bucket": {
      "type": "object",
      "required": [
        "dimension_id",
        "bucket_id",
        "bucket_value",
        "return_count",
        "total_return",
        "avg_signal_return",
        "min_signal_return",
        "max_signal_return",
        "positive_rate",
        "max_drawdown",
        "cost_drag_bps",
        "notional_usd",
        "source_row_indices"
      ],
      "properties": {
        "dimension_id": {"type": "string"},
        "bucket_id": {"type": "string"},
        "bucket_value": {"type": "string"},
        "return_count": {"type": "integer", "minimum": 0},
        "total_return": {"type": "number"},
        "avg_signal_return": {"type": ["number", "null"]},
        "min_signal_return": {"type": ["number", "null"]},
        "max_signal_return": {"type": ["number", "null"]},
        "positive_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": "number", "minimum": 0},
        "notional_usd": {"type": "number", "minimum": 0},
        "source_row_indices": {
          "type": "array",
          "items": {"type": "integer", "minimum": 0}
        }
      },
      "additionalProperties": false
    }
  }
}
