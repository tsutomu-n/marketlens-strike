{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_suite.v1.schema.json",
  "type": "object",
  "required": ["schema_version", "suite_id", "cases", "members"],
  "properties": {
    "schema_version": {"const": "strategy_backtest_suite.v1"},
    "suite_id": {"type": "string", "minLength": 1},
    "selection_metric": {"type": "string"},
    "selection_direction": {"enum": ["maximize", "minimize", "auto"]},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["case_id"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1},
          "enabled": {"type": "boolean"},
          "backtest": {
            "type": "object",
            "properties": {
              "split_method": {
                "enum": ["single_window", "walk_forward", "purged_walk_forward"]
              },
              "era_unit": {"enum": ["trading_day", "week", "month"]},
              "label_horizon_minutes": {"type": "integer", "minimum": 1},
              "purge_minutes": {"type": "integer", "minimum": 0},
              "embargo_minutes": {"type": "integer", "minimum": 0},
              "min_trade_count": {"type": "integer", "minimum": 0},
              "primary_metric": {"type": "string"},
              "pass_thresholds": {
                "type": "object",
                "additionalProperties": {"type": "number"}
              },
              "initial_capital_usd": {"type": "number", "minimum": 100, "maximum": 50000},
              "evaluation_start_at": {
                "type": ["string", "null"],
                "format": "date-time",
                "pattern": "(Z|[+-][0-9]{2}:[0-9]{2})$"
              },
              "evaluation_end_at": {
                "type": ["string", "null"],
                "format": "date-time",
                "pattern": "(Z|[+-][0-9]{2}:[0-9]{2})$"
              }
            },
            "additionalProperties": false
          },
          "resampling": {
            "type": "object",
            "properties": {
              "method": {
                "enum": ["none", "return_bootstrap", "block_bootstrap"]
              },
              "iterations": {"type": "integer", "minimum": 1},
              "seed": {"type": "integer"},
              "block_size": {"type": "integer", "minimum": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["spec_path"],
        "properties": {
          "spec_path": {"type": "string", "minLength": 1},
          "enabled": {"type": "boolean"},
          "case_ids": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
