{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_daily_brief.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "producer",
    "data_dir",
    "source_artifacts",
    "summary",
    "items",
    "paper_execution_allowed",
    "live_allowed",
    "boundary"
  ],
  "properties": {
    "schema_version": {"const": "strategy_daily_brief.v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": {"const": "sis"},
        "command": {"const": "strategy-daily-brief"}
      },
      "additionalProperties": false
    },
    "data_dir": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"
    },
    "source_artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_artifact"}
    },
    "summary": {"$ref": "#/$defs/summary"},
    "items": {
      "type": "array",
      "items": {"$ref": "#/$defs/item"}
    },
    "paper_execution_allowed": {"const": false},
    "live_allowed": {"const": false},
    "boundary": {"$ref": "#/$defs/boundary"}
  },
  "$defs": {
    "category": {
      "enum": [
        "broken_artifact",
        "pending_human_review",
        "crypto_perp_gate_follow_up",
        "crypto_perp_truth_cycle_follow_up",
        "normal_paper_gap",
        "drift_review_needed",
        "learning_request_pending",
        "ai_review_follow_up",
        "boundary_violation"
      ]
    },
    "severity": {"enum": ["info", "warning", "error"]},
    "source_artifact": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"
        },
        "sha256": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
        "schema_version": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "item": {
      "type": "object",
      "required": ["category", "severity", "path", "reason"],
      "properties": {
        "category": {"$ref": "#/$defs/category"},
        "severity": {"$ref": "#/$defs/severity"},
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"
        },
        "schema_version": {"type": ["string", "null"]},
        "strategy_id": {"type": ["string", "null"]},
        "status": {"type": ["string", "null"]},
        "action": {"type": ["string", "null"]},
        "reason": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": [
        "scanned_json_count",
        "broken_artifact_count",
        "pending_human_review_count",
        "crypto_perp_gate_follow_up_count",
        "crypto_perp_truth_cycle_follow_up_count",
        "normal_paper_gap_count",
        "drift_review_needed_count",
        "learning_request_pending_count",
        "ai_review_follow_up_count",
        "boundary_violation_count",
        "total_item_count"
      ],
      "properties": {
        "scanned_json_count": {"type": "integer", "minimum": 0},
        "broken_artifact_count": {"type": "integer", "minimum": 0},
        "pending_human_review_count": {"type": "integer", "minimum": 0},
        "crypto_perp_gate_follow_up_count": {"type": "integer", "minimum": 0},
        "crypto_perp_truth_cycle_follow_up_count": {"type": "integer", "minimum": 0},
        "normal_paper_gap_count": {"type": "integer", "minimum": 0},
        "drift_review_needed_count": {"type": "integer", "minimum": 0},
        "learning_request_pending_count": {"type": "integer", "minimum": 0},
        "ai_review_follow_up_count": {"type": "integer", "minimum": 0},
        "boundary_violation_count": {"type": "integer", "minimum": 0},
        "total_item_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
