{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_comparison.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "comparison_id",
    "created_at",
    "source_metrics_path",
    "source_metrics_hash",
    "source_suite_result_path",
    "source_suite_result_hash",
    "source_adapter_spike_path",
    "source_adapter_spike_hash",
    "source_external_result_path",
    "source_external_result_hash",
    "source_portfolio_comparison_path",
    "source_portfolio_comparison_hash",
    "source_metric_extension_path",
    "source_metric_extension_hash",
    "source_report_extension_path",
    "source_report_extension_hash",
    "native_result",
    "method_results",
    "suite_results",
    "adapter_spike",
    "external_results",
    "portfolio_comparison",
    "metric_extension",
    "report_extension",
    "comparison_diagnostics",
    "framework_adapters",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used"
  ],
  "properties": {
    "schema_version": {"const": "strategy_backtest_comparison.v1"},
    "comparison_id": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "created_at": {"type": "string"},
    "source_metrics_path": {"type": "string"},
    "source_metrics_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "source_suite_result_path": {"type": ["string", "null"]},
    "source_suite_result_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_adapter_spike_path": {"type": ["string", "null"]},
    "source_adapter_spike_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_external_result_path": {"type": ["string", "null"]},
    "source_external_result_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_portfolio_comparison_path": {"type": ["string", "null"]},
    "source_portfolio_comparison_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_metric_extension_path": {"type": ["string", "null"]},
    "source_metric_extension_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_report_extension_path": {"type": ["string", "null"]},
    "source_report_extension_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "native_result": {
      "type": "object",
      "required": ["engine_id", "strategy_id", "backtest_passed"],
      "properties": {
        "engine_id": {"const": "strategy_authoring_native"},
        "strategy_id": {"type": ["string", "null"]},
        "schema_version": {"type": ["string", "null"]},
        "backtest_passed": {"type": ["boolean", "null"]},
        "signals_considered": {"type": ["integer", "null"], "minimum": 0},
        "executed_count": {"type": ["integer", "null"], "minimum": 0},
        "blocked_count": {"type": ["integer", "null"], "minimum": 0},
        "trade_count": {"type": ["integer", "null"], "minimum": 0},
        "total_return": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": ["number", "null"]},
        "win_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "avg_signal_return": {"type": ["number", "null"]},
        "total_notional_usd": {"type": ["number", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "method_results": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/method_result"}
    },
    "suite_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/suite_result"}
    },
    "adapter_spike": {
      "anyOf": [
        {"$ref": "#/$defs/adapter_spike"},
        {"type": "null"}
      ]
    },
    "external_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/external_result"}
    },
    "portfolio_comparison": {
      "anyOf": [
        {"$ref": "#/$defs/portfolio_comparison"},
        {"type": "null"}
      ]
    },
    "metric_extension": {
      "anyOf": [
        {"$ref": "#/$defs/metric_extension"},
        {"type": "null"}
      ]
    },
    "report_extension": {
      "anyOf": [
        {"$ref": "#/$defs/report_extension"},
        {"type": "null"}
      ]
    },
    "comparison_diagnostics": {"$ref": "#/$defs/comparison_diagnostics"},
    "framework_adapters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "framework_id",
          "module",
          "distribution",
          "adapter_role",
          "adoption_note",
          "status",
          "runs_in_this_command"
        ],
        "properties": {
          "framework_id": {
            "enum": [
              "vectorbt",
              "bt",
              "backtesting",
              "zipline_reloaded",
              "backtrader",
              "quantstats",
              "empyrical_reloaded",
              "pyfolio_reloaded",
              "qstrader"
            ]
          },
          "module": {"type": "string"},
          "distribution": {"type": "string"},
          "adapter_role": {"type": "string"},
          "adoption_note": {"type": "string"},
          "status": {"enum": ["installed", "not_installed"]},
          "version": {"type": ["string", "null"]},
          "license": {"type": ["string", "null"]},
          "requires_python": {"type": ["string", "null"]},
          "license_classifiers": {"type": "array", "items": {"type": "string"}},
          "runs_in_this_command": {"const": false}
        },
        "additionalProperties": false
      }
    },
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false}
  },
  "additionalProperties": false,
  "$defs": {
    "method_metrics": {
      "type": "object",
      "required": [
        "trade_count",
        "total_return",
        "max_drawdown",
        "cost_drag_bps",
        "stale_rejected_count",
        "halt_rejected_count"
      ],
      "properties": {
        "trade_count": {"type": ["integer", "null"], "minimum": 0},
        "total_return": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": ["number", "null"]},
        "stale_rejected_count": {"type": ["integer", "null"], "minimum": 0},
        "halt_rejected_count": {"type": ["integer", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "method_era": {
      "type": "object",
      "required": ["era", "signal_count", "executed_count", "metrics"],
      "properties": {
        "era": {"type": ["string", "null"]},
        "signal_count": {"type": ["integer", "null"], "minimum": 0},
        "executed_count": {"type": ["integer", "null"], "minimum": 0},
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    },
    "method_variant": {
      "type": "object",
      "required": ["variant_id", "parameters", "backtest_passed", "metrics"],
      "properties": {
        "variant_id": {"type": ["string", "null"]},
        "parameters": {"type": ["object", "null"]},
        "backtest_passed": {"type": ["boolean", "null"]},
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    },
    "method_result": {
      "type": "object",
      "required": [
        "method_id",
        "method_type",
        "engine_id",
        "status",
        "metrics"
      ],
      "properties": {
        "method_id": {
          "enum": [
            "strategy_authoring_native_overall",
            "strategy_authoring_walk_forward",
            "strategy_authoring_optimizer_sweep"
          ]
        },
        "method_type": {
          "enum": ["native_overall", "walk_forward", "parameter_sweep"]
        },
        "engine_id": {"const": "strategy_authoring_native"},
        "status": {"const": "available"},
        "backtest_passed": {"type": ["boolean", "null"]},
        "split_method": {
          "type": ["string", "null"],
          "enum": ["single_window", "walk_forward", "purged_walk_forward", null]
        },
        "era_unit": {
          "type": ["string", "null"],
          "enum": ["trading_day", "week", "month", null]
        },
        "signals_considered": {"type": ["integer", "null"], "minimum": 0},
        "executed_count": {"type": ["integer", "null"], "minimum": 0},
        "blocked_count": {"type": ["integer", "null"], "minimum": 0},
        "era_count": {"type": ["integer", "null"], "minimum": 0},
        "eras": {
          "type": "array",
          "items": {"$ref": "#/$defs/method_era"}
        },
        "selection_metric": {"type": ["string", "null"]},
        "selection_direction": {
          "type": ["string", "null"],
          "enum": ["maximize", "minimize", "auto", null]
        },
        "resolved_selection_direction": {
          "type": ["string", "null"],
          "enum": ["maximize", "minimize", null]
        },
        "variant_count": {"type": ["integer", "null"], "minimum": 0},
        "best_variant": {
          "anyOf": [
            {"$ref": "#/$defs/method_variant"},
            {"type": "null"}
          ]
        },
        "variants": {
          "type": "array",
          "items": {"$ref": "#/$defs/method_variant"}
        },
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    },
    "suite_selection": {
      "type": "object",
      "required": ["metric", "direction", "resolved_direction"],
      "properties": {
        "metric": {"type": "string"},
        "direction": {"enum": ["maximize", "minimize", "auto"]},
        "resolved_direction": {"enum": ["maximize", "minimize"]}
      },
      "additionalProperties": false
    },
    "suite_aggregate": {
      "type": "object",
      "required": [
        "run_count",
        "strategy_count",
        "case_count",
        "passed_count",
        "failed_count",
        "trade_count",
        "total_return",
        "cost_drag_bps"
      ],
      "properties": {
        "run_count": {"type": "integer", "minimum": 0},
        "strategy_count": {"type": "integer", "minimum": 0},
        "case_count": {"type": "integer", "minimum": 0},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "trade_count": {"type": "integer", "minimum": 0},
        "total_return": {"type": "number"},
        "cost_drag_bps": {"type": "number"}
      },
      "additionalProperties": false
    },
    "suite_run": {
      "type": "object",
      "required": [
        "run_id",
        "case_id",
        "strategy_id",
        "signal_count",
        "method_id",
        "method_type",
        "backtest_passed",
        "metrics"
      ],
      "properties": {
        "run_id": {"type": ["string", "null"]},
        "case_id": {"type": ["string", "null"]},
        "strategy_id": {"type": ["string", "null"]},
        "signal_count": {"type": ["integer", "null"], "minimum": 0},
        "method_id": {"type": ["string", "null"]},
        "method_type": {"type": ["string", "null"]},
        "base_method_id": {"type": ["string", "null"]},
        "resampling": {
          "anyOf": [
            {"$ref": "#/$defs/resampling_result"},
            {"type": "null"}
          ]
        },
        "backtest_passed": {"type": ["boolean", "null"]},
        "split_method": {
          "type": ["string", "null"],
          "enum": ["single_window", "walk_forward", "purged_walk_forward", null]
        },
        "era_unit": {
          "type": ["string", "null"],
          "enum": ["trading_day", "week", "month", null]
        },
        "label_horizon_minutes": {"type": ["integer", "null"], "minimum": 1},
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    },
    "suite_method_row": {
      "type": "object",
      "required": [
        "method_id",
        "method_type",
        "split_method",
        "era_unit",
        "case_ids",
        "run_count",
        "passed_count",
        "failed_count"
      ],
      "properties": {
        "method_id": {"type": "string"},
        "method_type": {"type": "string"},
        "base_method_id": {"type": ["string", "null"]},
        "resampling_method": {
          "type": ["string", "null"],
          "enum": ["none", "return_bootstrap", "block_bootstrap", null]
        },
        "split_method": {"type": ["string", "null"]},
        "era_unit": {"type": ["string", "null"]},
        "case_ids": {"type": "array", "items": {"type": "string"}},
        "run_count": {"type": "integer", "minimum": 0},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "resampling_result": {
      "type": "object",
      "required": ["method", "iterations", "seed", "block_size", "status"],
      "properties": {
        "method": {"enum": ["none", "return_bootstrap", "block_bootstrap"]},
        "iterations": {"type": "integer", "minimum": 1},
        "seed": {"type": "integer"},
        "block_size": {"type": "integer", "minimum": 1},
        "status": {"enum": ["not_requested", "completed", "skipped"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "source_result_count": {"type": "integer", "minimum": 0},
        "sample_size": {"type": "integer", "minimum": 0},
        "iteration_count": {"type": "integer", "minimum": 0},
        "total_return_min": {"type": "number"},
        "total_return_p05": {"type": "number"},
        "total_return_p50": {"type": "number"},
        "total_return_p95": {"type": "number"},
        "total_return_max": {"type": "number"},
        "positive_total_return_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "suite_method_matrix": {
      "type": "object",
      "required": ["method_count", "counts_by_method", "methods"],
      "properties": {
        "method_count": {"type": "integer", "minimum": 0},
        "counts_by_method": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "methods": {
          "type": "array",
          "items": {"$ref": "#/$defs/suite_method_row"}
        }
      },
      "additionalProperties": false
    },
    "suite_result": {
      "type": "object",
      "required": [
        "suite_id",
        "schema_version",
        "selection",
        "aggregate",
        "method_matrix",
        "best_run",
        "runs",
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "exchange_write_used"
      ],
      "properties": {
        "suite_id": {"type": ["string", "null"]},
        "schema_version": {
          "type": ["string", "null"],
          "enum": ["strategy_backtest_suite_result.v1", null]
        },
        "selection": {"$ref": "#/$defs/suite_selection"},
        "aggregate": {"$ref": "#/$defs/suite_aggregate"},
        "method_matrix": {"$ref": "#/$defs/suite_method_matrix"},
        "best_run": {
          "anyOf": [
            {"$ref": "#/$defs/suite_run"},
            {"type": "null"}
          ]
        },
        "runs": {"type": "array", "items": {"$ref": "#/$defs/suite_run"}},
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    },
    "diagnostic_threshold_failure": {
      "type": "object",
      "required": ["metric", "actual", "threshold"],
      "properties": {
        "metric": {"type": "string"},
        "actual": {"type": ["number", "null"]},
        "threshold": {"type": ["number", "null"]}
      },
      "additionalProperties": false
    },
    "diagnostic_metric_row": {
      "type": "object",
      "required": [
        "trade_count",
        "total_return",
        "max_drawdown",
        "cost_drag_bps"
      ],
      "properties": {
        "trade_count": {"type": ["integer", "null"], "minimum": 0},
        "total_return": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": ["number", "null"]}
      },
      "additionalProperties": true
    },
    "diagnostic_era": {
      "allOf": [
        {"$ref": "#/$defs/diagnostic_metric_row"},
        {
          "type": "object",
          "required": ["method_id", "era"],
          "properties": {
            "method_id": {"type": ["string", "null"]},
            "era": {"type": ["string", "null"]}
          }
        }
      ]
    },
    "diagnostic_suite_run": {
      "allOf": [
        {"$ref": "#/$defs/diagnostic_metric_row"},
        {
          "type": "object",
          "required": [
            "suite_id",
            "run_id",
            "case_id",
            "method_id",
            "strategy_id",
            "backtest_passed"
          ],
          "properties": {
            "suite_id": {"type": ["string", "null"]},
            "run_id": {"type": ["string", "null"]},
            "case_id": {"type": ["string", "null"]},
            "method_id": {"type": ["string", "null"]},
            "strategy_id": {"type": ["string", "null"]},
            "backtest_passed": {"type": ["boolean", "null"]}
          }
        }
      ]
    },
    "comparison_diagnostics": {
      "type": "object",
      "required": [
        "threshold_failures",
        "weakest_eras",
        "suite_best_runs",
        "suite_failed_runs",
        "diagnostic_notes"
      ],
      "properties": {
        "threshold_failures": {
          "type": "array",
          "items": {"$ref": "#/$defs/diagnostic_threshold_failure"}
        },
        "weakest_eras": {
          "type": "array",
          "items": {"$ref": "#/$defs/diagnostic_era"}
        },
        "suite_best_runs": {
          "type": "array",
          "items": {"$ref": "#/$defs/diagnostic_suite_run"}
        },
        "suite_failed_runs": {
          "type": "array",
          "items": {"$ref": "#/$defs/diagnostic_suite_run"}
        },
        "diagnostic_notes": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "adapter_spike_candidate": {
      "type": "object",
      "required": [
        "framework_id",
        "adapter_role",
        "status",
        "adoption_status",
        "adoption_blockers",
        "dependency_added",
        "engine_run",
        "permits_live_order",
        "wallet_used",
        "exchange_write_used"
      ],
      "properties": {
        "framework_id": {
          "enum": [
            "vectorbt",
            "bt",
            "backtesting",
            "zipline_reloaded",
            "backtrader",
            "quantstats",
            "empyrical_reloaded",
            "pyfolio_reloaded",
            "qstrader",
            null
          ]
        },
        "adapter_role": {"type": ["string", "null"]},
        "status": {"enum": ["installed", "not_installed", null]},
        "version": {"type": ["string", "null"]},
        "adoption_status": {
          "type": ["string", "null"],
          "enum": [
            "metadata_review_required",
            "requires_temporary_install_spike",
            "blocked_pending_install_spike",
            "blocked_pending_license_review",
            null
          ]
        },
        "adoption_blockers": {"type": "array", "items": {"type": "string"}},
        "dependency_added": {"const": false},
        "engine_run": {"const": false},
        "permits_live_order": {"const": false},
        "wallet_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    },
    "adapter_spike": {
      "type": "object",
      "required": [
        "schema_version",
        "created_at",
        "dependency_added",
        "external_engine_run",
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "exchange_write_used",
        "decision",
        "candidates"
      ],
      "properties": {
        "schema_version": {
          "type": ["string", "null"],
          "enum": ["strategy_backtest_adapter_spike.v1", null]
        },
        "created_at": {"type": ["string", "null"]},
        "dependency_added": {"const": false},
        "external_engine_run": {"const": false},
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "exchange_write_used": {"const": false},
        "decision": {"type": "object"},
        "candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/adapter_spike_candidate"}
        }
      },
      "additionalProperties": false
    },
    "external_result": {
      "type": "object",
      "required": [
        "framework_id",
        "adapter_role",
        "status",
        "framework_version",
        "runner_mode",
        "run_status",
        "reason_codes",
        "dependency_added",
        "engine_run",
        "permits_live_order",
        "wallet_used",
        "exchange_write_used",
        "metrics"
      ],
      "properties": {
        "framework_id": {
          "enum": [
            "vectorbt",
            "bt",
            "backtesting",
            "zipline_reloaded",
            "backtrader",
            "quantstats",
            "empyrical_reloaded",
            "pyfolio_reloaded",
            "qstrader",
            null
          ]
        },
        "adapter_role": {"type": ["string", "null"]},
        "status": {"enum": ["installed", "not_installed", null]},
        "framework_version": {"type": ["string", "null"]},
        "runner_mode": {
          "enum": [
            "not_installed_in_current_env",
            "temporary_or_optional_import",
            "installed_without_runner",
            null
          ]
        },
        "run_status": {"enum": ["completed", "skipped", "failed", null]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "dependency_added": {"const": false},
        "engine_run": {"type": ["boolean", "null"]},
        "permits_live_order": {"const": false},
        "wallet_used": {"const": false},
        "exchange_write_used": {"const": false},
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    },
    "portfolio_comparison": {
      "type": "object",
      "required": [
        "framework_id",
        "adapter_role",
        "framework_version",
        "runner_mode",
        "run_status",
        "reason_codes",
        "dependency_added",
        "engine_run",
        "allocation_rule_id",
        "rebalance_cadence",
        "portfolio_return",
        "max_drawdown",
        "turnover",
        "rebalance_count",
        "permits_live_order",
        "wallet_used",
        "exchange_write_used"
      ],
      "properties": {
        "framework_id": {"enum": ["bt", null]},
        "adapter_role": {"type": ["string", "null"]},
        "framework_version": {"type": ["string", "null"]},
        "runner_mode": {
          "enum": [
            "not_installed_in_current_env",
            "temporary_or_optional_import",
            "installed_without_runner",
            null
          ]
        },
        "run_status": {"enum": ["completed", "skipped", "failed", null]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "dependency_added": {"const": false},
