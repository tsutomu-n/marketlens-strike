{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "trade_xyz_ws_capture_manifest.v1",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "dex",
    "started_at",
    "ended_at",
    "duration_seconds",
    "subscriptions",
    "symbols",
    "raw_paths",
    "row_count",
    "bytes_written",
    "connection_count",
    "reconnect_count",
    "error_count",
    "subscription_response_count",
    "pong_count",
    "heartbeat_sent_count",
    "dry_run"
  ],
  "properties": {
    "schema_version": { "const": "trade_xyz_ws_capture_manifest.v1" },
    "source": { "type": "string" },
    "dex": { "type": "string" },
    "started_at": { "type": "string" },
    "ended_at": { "type": "string" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "subscriptions": { "type": "array", "items": { "type": "string" } },
    "symbols": { "type": "array", "items": { "type": "string" } },
    "raw_paths": { "type": "array", "items": { "type": "string" } },
    "row_count": { "type": "integer", "minimum": 0 },
    "bytes_written": { "type": "integer", "minimum": 0 },
    "connection_count": { "type": "integer", "minimum": 0 },
    "reconnect_count": { "type": "integer", "minimum": 0 },
    "error_count": { "type": "integer", "minimum": 0 },
    "subscription_response_count": { "type": "integer", "minimum": 0 },
    "pong_count": { "type": "integer", "minimum": 0 },
    "heartbeat_sent_count": { "type": "integer", "minimum": 0 },
    "dry_run": { "type": "boolean" },
    "block_reasons": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
