{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_idea.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "idea_id",
    "created_at",
    "title",
    "hypothesis",
    "mechanism",
    "timeframe",
    "instruments",
    "required_input_contract_ids",
    "baseline",
    "invalidation",
    "risk",
    "execution_assumptions",
    "authoring_intent",
    "boundary"
  ],
  "properties": {
    "schema_version": {"const": "strategy_idea.v1"},
    "idea_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "title": {"type": "string", "minLength": 1},
    "hypothesis": {"type": "string", "minLength": 1},
    "mechanism": {"type": "string", "minLength": 1},
    "timeframe": {"type": "string", "minLength": 1},
    "instruments": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "required_input_contract_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "baseline": {
      "type": "object",
      "required": ["name", "expected_to_beat"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "expected_to_beat": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "invalidation": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "risk": {
      "type": "object",
      "required": ["max_position_notional_usd", "max_daily_loss_usd", "kill_conditions"],
      "properties": {
        "max_position_notional_usd": {"type": "number", "exclusiveMinimum": 0},
        "max_daily_loss_usd": {"type": "number", "exclusiveMinimum": 0},
        "kill_conditions": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "execution_assumptions": {
      "type": "object",
      "required": ["order_type", "slippage_model"],
      "properties": {
        "order_type": {"type": "string", "minLength": 1},
        "slippage_model": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "authoring_intent": {
      "type": "object",
      "required": ["target", "auto_generate_spec"],
      "properties": {
        "target": {"const": "strategy_authoring_draft"},
        "auto_generate_spec": {"const": false}
      },
      "additionalProperties": false
    },
    "boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
