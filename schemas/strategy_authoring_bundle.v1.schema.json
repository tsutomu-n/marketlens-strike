{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_authoring_bundle.v1.schema.json",
  "type": "object",
  "required": ["schema_version", "bundle_id", "members"],
  "properties": {
    "schema_version": {"const": "strategy_authoring_bundle.v1"},
    "bundle_id": {"type": "string"},
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["spec_path"],
        "properties": {
          "spec_path": {"type": "string"},
          "allocation_weight": {"type": "number", "minimum": 0},
          "enabled": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "portfolio": {
      "type": "object",
      "properties": {
        "allocation_method": {"enum": ["fixed_weight", "equal_weight", "risk_parity"]},
        "max_total_allocation_weight": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "selection_metric": {"type": "string"},
        "selection_direction": {"enum": ["maximize", "minimize"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
