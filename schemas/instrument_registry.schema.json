{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InstrumentSpec",
  "type": "object",
  "required": [
    "venue",
    "canonical_symbol",
    "venue_symbol",
    "asset_class",
    "api_readable"
  ],
  "properties": {
    "venue": {
      "type": "string",
      "enum": [
        "gtrade",
        "ostium"
      ]
    },
    "canonical_symbol": {
      "type": "string"
    },
    "venue_symbol": {
      "type": "string"
    },
    "pair_index": {
      "type": [
        "integer",
        "null"
      ]
    },
    "pair_id": {
      "type": [
        "integer",
        "null"
      ]
    },
    "asset_class": {
      "type": "string",
      "enum": [
        "index",
        "commodity",
        "unknown"
      ]
    },
    "chain": {
      "type": [
        "string",
        "array",
        "null"
      ]
    },
    "collateral": {
      "type": [
        "string",
        "array",
        "null"
      ]
    },
    "api_readable": {
      "type": "boolean"
    },
    "api_orderable": {
      "type": "boolean"
    },
    "execution_price_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "liquidation_price_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "opening_fee_bps": {
      "type": [
        "number",
        "null"
      ]
    },
    "rollover_fee_per_block": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollover_rate_long": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollover_rate_short": {
      "type": [
        "string",
        "null"
      ]
    },
    "open_interest": {
      "type": [
        "string",
        "null"
      ]
    },
    "buy_open_interest": {
      "type": [
        "string",
        "null"
      ]
    },
    "sell_open_interest": {
      "type": [
        "string",
        "null"
      ]
    },
    "max_open_interest": {
      "type": [
        "string",
        "null"
      ]
    },
    "max_leverage": {
      "type": [
        "number",
        "null"
      ]
    },
    "overnight_max_leverage": {
      "type": [
        "number",
        "null"
      ]
    },
    "trading_hours_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "is_day_trading_closed": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "seconds_to_toggle_is_day_trading_closed": {
      "type": [
        "integer",
        "null"
      ]
    },
    "active": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
