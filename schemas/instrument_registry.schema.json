{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InstrumentSpecV2",
  "type": "object",
  "required": [
    "venue",
    "canonical_symbol",
    "venue_symbol",
    "asset_class",
    "api_readable",
    "api_orderable",
    "active"
  ],
  "properties": {
    "venue": {
      "type": "string",
      "enum": [
        "trade_xyz",
        "lighter",
        "bitmex_readonly",
        "legacy_gtrade",
        "legacy_ostium",
        "gtrade",
        "ostium"
      ]
    },
    "canonical_symbol": {
      "type": "string"
    },
    "venue_symbol": {
      "type": "string"
    },
    "asset_class": {
      "type": "string",
      "enum": [
        "equity",
        "etf",
        "index",
        "basket_index",
        "crypto_beta_equity",
        "commodity",
        "unknown"
      ]
    },
    "dex": {
      "type": [
        "string",
        "null"
      ]
    },
    "coin": {
      "type": [
        "string",
        "null"
      ]
    },
    "asset_id": {
      "type": [
        "integer",
        "null"
      ]
    },
    "perp_dex_index": {
      "type": [
        "integer",
        "null"
      ]
    },
    "index_in_meta": {
      "type": [
        "integer",
        "null"
      ]
    },
    "real_market_symbol": {
      "type": [
        "string",
        "null"
      ]
    },
    "country": {
      "type": [
        "string",
        "null"
      ]
    },
    "currency": {
      "type": [
        "string",
        "null"
      ]
    },
    "fee_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "growth",
        "standard",
        "observed",
        "unknown",
        null
      ]
    },
    "taker_fee_bps": {
      "type": [
        "number",
        "null"
      ]
    },
    "maker_fee_bps": {
      "type": [
        "number",
        "null"
      ]
    },
    "max_leverage": {
      "type": [
        "number",
        "null"
      ]
    },
    "discovery_bound_bps": {
      "type": [
        "number",
        "null"
      ]
    },
    "oi_cap_usd": {
      "type": [
        "number",
        "null"
      ]
    },
    "external_session": {
      "type": [
        "string",
        "null"
      ]
    },
    "internal_session": {
      "type": [
        "string",
        "null"
      ]
    },
    "pair_index": {
      "type": [
        "integer",
        "null"
      ]
    },
    "pair_id": {
      "type": [
        "integer",
        "null"
      ]
    },
    "chain": {
      "type": [
        "string",
        "array",
        "null"
      ]
    },
    "collateral": {
      "type": [
        "string",
        "array",
        "null"
      ]
    },
    "api_readable": {
      "type": "boolean"
    },
    "api_orderable": {
      "type": "boolean"
    },
    "active": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
