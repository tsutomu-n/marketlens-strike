{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ndx_strategy_lab_research_export_manifest.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "dag_id",
    "export_id",
    "created_at",
    "source_decision",
    "source_decision_id",
    "source_decision_path",
    "source_summary_path",
    "source_reason_codes",
    "source_thresholds",
    "feature_panel_path",
    "feature_panel_hash",
    "residuals_path",
    "residuals_hash",
    "neutralized_residuals_path",
    "neutralized_residuals_hash",
    "strategy_signals_path",
    "strategy_signals_hash",
    "strategy_signal_manifest_path",
    "strategy_signal_manifest_hash",
    "signal_count",
    "strategy_id",
    "strategy_family",
    "strategy_version",
    "generator_id",
    "tested_variant_count",
    "side_policy",
    "rank_policy",
    "hash_excludes",
    "replace_existing",
    "replaced_existing_artifact",
    "previous_strategy_signals_hash",
    "previous_strategy_signal_manifest_hash",
    "research_only",
    "permits_backtest",
    "permits_paper_candidate",
    "permits_paper_intent_preview",
    "permits_live_order",
    "external_api_used",
    "credentials_used",
    "wallet_used",
    "venue_write_used"
  ],
  "properties": {
    "schema_version": {"const": "ndx_strategy_lab_research_export_manifest.v1"},
    "dag_id": {"const": "HYP-NDX-001"},
    "export_id": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "created_at": {"type": "string"},
    "source_decision": {"const": "APPROVE_STRATEGY_LAB_EXPORT"},
    "source_decision_id": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "source_decision_path": {"type": "string"},
    "source_summary_path": {"type": "string"},
    "source_reason_codes": {"type": "array", "items": {"type": "string"}},
    "source_thresholds": {"type": "object"},
    "feature_panel_path": {"type": "string"},
    "feature_panel_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "residuals_path": {"type": "string"},
    "residuals_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "neutralized_residuals_path": {"type": "string"},
    "neutralized_residuals_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "strategy_signals_path": {"type": "string"},
    "strategy_signals_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "strategy_signal_manifest_path": {"type": "string"},
    "strategy_signal_manifest_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "signal_count": {"type": "integer", "minimum": 0},
    "strategy_id": {"const": "ndx_open_gap_residual_v1"},
    "strategy_family": {"const": "ndx_open_gap_residual"},
    "strategy_version": {"const": "v1"},
    "generator_id": {"const": "ndx_layer25_residual_research_export"},
    "tested_variant_count": {"const": 1},
    "side_policy": {"const": "residual_sign_directional_research_only"},
    "rank_policy": {"type": "string"},
    "hash_excludes": {"type": "array", "items": {"type": "string"}},
    "replace_existing": {"type": "boolean"},
    "replaced_existing_artifact": {"type": "boolean"},
    "previous_strategy_signals_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "previous_strategy_signal_manifest_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "research_only": {"const": true},
    "permits_backtest": {"const": false},
    "permits_paper_candidate": {"const": false},
    "permits_paper_intent_preview": {"const": false},
    "permits_live_order": {"const": false},
    "external_api_used": {"const": false},
    "credentials_used": {"const": false},
    "wallet_used": {"const": false},
    "venue_write_used": {"const": false}
  },
  "additionalProperties": true
}
