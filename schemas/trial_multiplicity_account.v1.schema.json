{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trial_multiplicity_account.v1.schema.json",
  "$defs": {
    "AdjustmentMethods": {
      "additionalProperties": false,
      "properties": {
        "benjamini_hochberg_fdr": {
          "$ref": "#/$defs/AdjustmentStatus"
        },
        "benjamini_yekutieli_fdr": {
          "$ref": "#/$defs/AdjustmentStatus"
        },
        "pbo": {
          "$ref": "#/$defs/AdjustmentStatus"
        },
        "white_reality_check": {
          "$ref": "#/$defs/AdjustmentStatus"
        },
        "deflated_sharpe_ratio": {
          "$ref": "#/$defs/AdjustmentStatus"
        }
      },
      "required": [
        "benjamini_hochberg_fdr",
        "benjamini_yekutieli_fdr",
        "pbo",
        "white_reality_check",
        "deflated_sharpe_ratio"
      ],
      "title": "AdjustmentMethods",
      "type": "object"
    },
    "AdjustmentStatus": {
      "enum": [
        "NOT_ESTIMABLE",
        "AVAILABLE"
      ],
      "title": "AdjustmentStatus",
      "type": "string"
    },
    "ArtifactRef": {
      "additionalProperties": false,
      "properties": {
        "ref_id": {
          "title": "Ref Id",
          "type": "string"
        },
        "schema_version": {
          "title": "Schema Version",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        }
      },
      "required": [
        "ref_id",
        "schema_version",
        "path",
        "sha256"
      ],
      "title": "ArtifactRef",
      "type": "object"
    },
    "EdgeCandidateBoundary": {
      "additionalProperties": false,
      "properties": {
        "paper_execution_allowed": {
          "const": false,
          "default": false,
          "title": "Paper Execution Allowed",
          "type": "boolean"
        },
        "live_allowed": {
          "const": false,
          "default": false,
          "title": "Live Allowed",
          "type": "boolean"
        },
        "permits_live_order": {
          "const": false,
          "default": false,
          "title": "Permits Live Order",
          "type": "boolean"
        },
        "live_conversion_allowed": {
          "const": false,
          "default": false,
          "title": "Live Conversion Allowed",
          "type": "boolean"
        },
        "wallet_used": {
          "const": false,
          "default": false,
          "title": "Wallet Used",
          "type": "boolean"
        },
        "signing_used": {
          "const": false,
          "default": false,
          "title": "Signing Used",
          "type": "boolean"
        },
        "exchange_write_used": {
          "const": false,
          "default": false,
          "title": "Exchange Write Used",
          "type": "boolean"
        },
        "production_exchange_write_allowed": {
          "const": false,
          "default": false,
          "title": "Production Exchange Write Allowed",
          "type": "boolean"
        },
        "production_exchange_write_used": {
          "const": false,
          "default": false,
          "title": "Production Exchange Write Used",
          "type": "boolean"
        },
        "live_order_submitted": {
          "const": false,
          "default": false,
          "title": "Live Order Submitted",
          "type": "boolean"
        },
        "auto_promote": {
          "const": false,
          "default": false,
          "title": "Auto Promote",
          "type": "boolean"
        }
      },
      "title": "EdgeCandidateBoundary",
      "type": "object"
    },
    "ProducerInfo": {
      "additionalProperties": false,
      "properties": {
        "tool": {
          "const": "sis",
          "default": "sis",
          "title": "Tool",
          "type": "string"
        },
        "command": {
          "title": "Command",
          "type": "string"
        }
      },
      "required": [
        "command"
      ],
      "title": "ProducerInfo",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "trial_multiplicity_account.v1",
      "default": "trial_multiplicity_account.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "account_id": {
      "title": "Account Id",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/ProducerInfo"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/ArtifactRef"
      },
      "minItems": 1,
      "title": "Source Refs",
      "type": "array"
    },
    "candidate_run_id": {
      "title": "Candidate Run Id",
      "type": "string"
    },
    "candidate_count_total": {
      "minimum": 0,
      "title": "Candidate Count Total",
      "type": "integer"
    },
    "candidate_count_shortlisted": {
      "minimum": 0,
      "title": "Candidate Count Shortlisted",
      "type": "integer"
    },
    "candidate_count_rejected": {
      "minimum": 0,
      "title": "Candidate Count Rejected",
      "type": "integer"
    },
    "family_count": {
      "minimum": 0,
      "title": "Family Count",
      "type": "integer"
    },
    "family_trial_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Family Trial Counts",
      "type": "object"
    },
    "parameter_grid_hashes": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Parameter Grid Hashes",
      "type": "array"
    },
    "candidate_cluster_count": {
      "minimum": 0,
      "title": "Candidate Cluster Count",
      "type": "integer"
    },
    "effective_trial_count_status": {
      "$ref": "#/$defs/AdjustmentStatus"
    },
    "effective_trial_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Effective Trial Count"
    },
    "validation_peek_count": {
      "minimum": 0,
      "title": "Validation Peek Count",
      "type": "integer"
    },
    "rerank_count": {
      "minimum": 0,
      "title": "Rerank Count",
      "type": "integer"
    },
    "sealed_test_used_for_selection": {
      "const": false,
      "default": false,
      "title": "Sealed Test Used For Selection",
      "type": "boolean"
    },
    "success_only_reporting": {
      "const": false,
      "default": false,
      "title": "Success Only Reporting",
      "type": "boolean"
    },
    "adjustment_methods": {
      "$ref": "#/$defs/AdjustmentMethods"
    },
    "known_gaps": {
      "items": {
        "type": "string"
      },
      "title": "Known Gaps",
      "type": "array"
    },
    "boundary": {
      "$ref": "#/$defs/EdgeCandidateBoundary"
    }
  },
  "required": [
    "account_id",
    "created_at",
    "producer",
    "source_refs",
    "candidate_run_id",
    "candidate_count_total",
    "candidate_count_shortlisted",
    "candidate_count_rejected",
    "family_count",
    "parameter_grid_hashes",
    "candidate_cluster_count",
    "effective_trial_count_status",
    "validation_peek_count",
    "rerank_count",
    "adjustment_methods"
  ],
  "title": "TrialMultiplicityAccount",
  "type": "object"
}
