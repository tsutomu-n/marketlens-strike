{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_input_contract_update_proposal.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "proposal_id",
    "strategy_id",
    "created_at",
    "producer",
    "status",
    "source_artifacts",
    "proposed_changes",
    "requires_human_review",
    "auto_applied",
    "direct_contract_edit_allowed",
    "paper_execution_allowed",
    "live_allowed",
    "boundary",
    "feedback_boundary"
  ],
  "properties": {
    "schema_version": {"const": "strategy_input_contract_update_proposal.v1"},
    "proposal_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "strategy_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": {"const": "sis"},
        "command": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "READY_FOR_HUMAN_REVIEW",
        "NEEDS_SOURCE_CONTRACT_CONTEXT",
        "NO_CHANGES_RECOMMENDED",
        "BLOCKED_BOUNDARY_VIOLATION"
      ]
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source_artifact"}
    },
    "proposed_changes": {
      "type": "array",
      "items": {"$ref": "#/$defs/proposed_change"}
    },
    "blocked_reasons": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "requires_human_review": {"const": true},
    "auto_applied": {"const": false},
    "direct_contract_edit_allowed": {"const": false},
    "paper_execution_allowed": {"const": false},
    "live_allowed": {"const": false},
    "boundary": {"$ref": "#/$defs/stage_boundary"},
    "feedback_boundary": {"$ref": "#/$defs/feedback_boundary"}
  },
  "additionalProperties": false,
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": ["artifact_kind", "path", "sha256", "schema_version"],
      "properties": {
        "artifact_kind": {
          "enum": ["strategy_input_contract", "runtime_observation", "learning_event"]
        },
        "path": {"$ref": "#/$defs/safe_path"},
        "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "schema_version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "proposed_change": {
      "type": "object",
      "required": [
        "change_id",
        "target_section",
        "recommendation",
        "evidence_summary",
        "source_reason",
        "requires_human_review"
      ],
      "properties": {
        "change_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
        "target_section": {
          "enum": [
            "source_validation_expectations",
            "known_gaps",
            "execution_reality",
            "strategy_scope",
            "risk_assumption",
            "manual_note"
          ]
        },
        "recommendation": {"type": "string", "minLength": 1},
        "evidence_summary": {"type": "string", "minLength": 1},
        "source_reason": {"type": "string", "minLength": 1},
        "requires_human_review": {"const": true}
      },
      "additionalProperties": false
    },
    "safe_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"
    },
    "stage_boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    },
    "feedback_boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "permits_wallet",
        "permits_signing",
        "permits_exchange_write",
        "wallet_used",
        "signing_used",
        "exchange_write_used",
        "paper_execution_allowed",
        "live_allowed",
        "auto_applied",
        "direct_contract_edit_allowed"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "permits_wallet": {"const": false},
        "permits_signing": {"const": false},
        "permits_exchange_write": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false},
        "paper_execution_allowed": {"const": false},
        "live_allowed": {"const": false},
        "auto_applied": {"const": false},
        "direct_contract_edit_allowed": {"const": false}
      },
      "additionalProperties": false
    }
  }
}

