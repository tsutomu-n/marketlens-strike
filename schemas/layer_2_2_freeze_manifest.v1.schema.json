{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/layer_2_2_freeze_manifest.v1.schema.json",
  "title": "Layer 2.2 Freeze Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "dag_id",
    "pack_hash",
    "exit_decision",
    "review_ids",
    "artifact_hashes",
    "frozen_artifacts",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "layer_2_2_freeze_manifest.v1" },
    "dag_id": { "type": "string", "minLength": 1 },
    "pack_hash": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" },
    "exit_decision": { "const": "APPROVE_2_3" },
    "review_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "artifact_hashes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" }
    },
    "frozen_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
