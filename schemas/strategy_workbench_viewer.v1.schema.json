{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/strategy_workbench_viewer.v1.schema.json",
  "title": "Strategy Workbench Viewer Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "viewer_id",
    "created_at",
    "producer",
    "source_artifacts",
    "html_report_path",
    "html_report_hash",
    "artifact_count",
    "boundary_violation_count",
    "paper_execution_allowed",
    "live_allowed",
    "wallet_used",
    "signing_used",
    "exchange_write_used"
  ],
  "properties": {
    "schema_version": { "const": "strategy_workbench_viewer.v1" },
    "viewer_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "tool": { "type": "string" },
        "command": { "const": "strategy-workbench-viewer-build" },
        "version": { "type": ["string", "null"] }
      }
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source_artifact" }
    },
    "html_report_path": { "type": "string", "minLength": 1 },
    "html_report_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "artifact_count": { "type": "integer", "minimum": 1 },
    "boundary_violation_count": { "type": "integer", "minimum": 0 },
    "paper_execution_allowed": { "const": false },
    "live_allowed": { "const": false },
    "wallet_used": { "const": false },
    "signing_used": { "const": false },
    "exchange_write_used": { "const": false }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_key",
        "path",
        "sha256",
        "artifact_format",
        "title",
        "boundary_violations",
        "summary"
      ],
      "properties": {
        "artifact_key": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "artifact_format": { "enum": ["json", "markdown", "text"] },
        "schema_version": { "type": ["string", "null"] },
        "title": { "type": "string", "minLength": 1 },
        "status": { "type": ["string", "null"] },
        "boundary_violations": { "type": "array", "items": { "type": "string" } },
        "summary": { "$ref": "#/$defs/compact_summary" },
        "preview": { "type": ["string", "null"] }
      }
    },
    "compact_summary": {
      "type": "object",
      "properties": {
        "gate_id": { "type": "string" },
        "gate_status": { "type": "string" },
        "cycle_status": { "type": "string" },
        "human_summary": { "type": "string" },
        "report_id": { "type": "string" },
        "tournament_status": { "type": "string" },
        "leader_action": { "type": "string" },
        "primary_metric": { "type": "string" },
        "event_count": { "type": "integer" },
        "leader_actual_cash_result_usd": { "type": "number" },
        "proxy_gap_count": { "type": "integer" },
        "failed_condition_count": { "type": "integer" },
        "present_stage_count": { "type": "integer" },
        "missing_artifact_path_count": { "type": "integer" },
        "known_gap_count": { "type": "integer" },
        "stop_reason_count": { "type": "integer" },
        "strategy_id": { "type": "string" },
        "review_id": { "type": "string" },
        "decision_id": { "type": "string" },
        "plan_id": { "type": "string" },
        "manifest_id": { "type": "string" },
        "recommended_action": { "type": "string" },
        "latest_status": { "type": "string" },
        "open_action_count": { "type": "integer" },
        "pending_human_review_count": { "type": "integer" },
        "boundary_violation_count": { "type": "integer" },
        "first_stop_reason": { "type": "string" },
        "first_next_step": { "type": "string" },
        "first_next_step_purpose": { "type": "string" },
        "first_next_step_command": { "type": "string" },
        "first_next_step_requires_explicit_approval": { "type": "boolean" },
        "first_next_step_network_allowed": { "type": "boolean" },
        "first_next_step_exchange_write_allowed": { "type": "boolean" },
        "first_next_step_live_order_allowed": { "type": "boolean" },
        "first_stage_blocker": { "type": "string" },
        "first_stage_blocker_status": { "type": "string" },
        "first_stage_blocker_expected_cli_option": { "type": "string" },
        "first_stage_blocker_expected_artifact_hint": { "type": "string" },
        "first_stage_blocker_artifact_path": { "type": "string" }
      },
      "additionalProperties": { "$ref": "#/$defs/compact_summary_value" }
    },
    "compact_summary_value": {
      "type": ["string", "number", "integer", "boolean"]
    }
  }
}
