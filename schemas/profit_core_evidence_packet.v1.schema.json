{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/profit_core_evidence_packet.v1.schema.json",
  "title": "profit_core_evidence_packet.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "generated_at",
    "producer",
    "candidate_id",
    "source_refs",
    "claims",
    "claim_findings",
    "machine_summary",
    "boundary"
  ],
  "properties": {
    "schema_version": { "const": "profit_core_evidence_packet.v1" },
    "packet_id": { "$ref": "#/$defs/id" },
    "generated_at": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "command"],
      "properties": {
        "tool": { "const": "sis" },
        "command": { "const": "edge-candidate-evidence-packet-build" }
      }
    },
    "candidate_id": { "$ref": "#/$defs/id" },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact_ref" }
    },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "claim_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim_finding" }
    },
    "machine_summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "protocol_id",
        "mode",
        "candidate_set_id",
        "candidate_id",
        "candidate_decision",
        "bridge_status",
        "backtest_gate_state",
        "no_trade_comparison_present",
        "virtual_gate_state",
        "cash_metric_basis",
        "evidence_bases",
        "actual_cash_available",
        "actual_cash",
        "permits_live_order",
        "production_exchange_write_used",
        "live_order_submitted",
        "profit_evidence",
        "claim_count",
        "finding_count"
      ],
      "properties": {
        "protocol_id": { "$ref": "#/$defs/id" },
        "mode": { "enum": ["verification_throughput", "risk_taker_sprint"] },
        "candidate_set_id": { "$ref": "#/$defs/id" },
        "candidate_id": { "$ref": "#/$defs/id" },
        "candidate_decision": { "type": "string", "minLength": 1 },
        "bridge_status": { "type": ["string", "null"] },
        "backtest_gate_state": {
          "enum": ["KILL", "INCONCLUSIVE_DATA", "RESEARCH_ONLY", "SHORTLIST_FOR_VIRTUAL"]
        },
        "no_trade_comparison_present": { "type": "boolean" },
        "virtual_gate_state": {
          "enum": [
            "LOCAL_MOCK_VERIFIED",
            "BLOCKED_BY_CANDIDATE_STATE",
            "BLOCKED_BY_BACKTEST_GATE",
            "BLOCKED_BY_MULTIPLICITY_ACCOUNT",
            "BLOCKED_BY_VIRTUAL_LIFECYCLE",
            "BLOCKED_BY_ARTIFACT_MISMATCH"
          ]
        },
        "cash_metric_basis": { "const": "virtual_exchange" },
        "evidence_bases": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "actual_cash_available": { "const": false },
        "actual_cash": { "const": false },
        "permits_live_order": { "const": false },
        "production_exchange_write_used": { "const": false },
        "live_order_submitted": { "const": false },
        "profit_evidence": { "const": false },
        "claim_count": { "type": "integer", "minimum": 0 },
        "finding_count": { "type": "integer", "minimum": 0 }
      }
    },
    "boundary": { "$ref": "#/$defs/boundary" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_role", "path", "sha256", "schema_version"],
      "properties": {
        "artifact_role": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "schema_version": { "type": ["string", "null"] }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "claim_type",
        "claimed",
        "requested_evidence_basis",
        "comparison_ref",
        "text"
      ],
      "properties": {
        "claim_id": { "$ref": "#/$defs/id" },
        "claim_type": { "type": "string", "minLength": 1 },
        "claimed": { "type": "boolean" },
        "requested_evidence_basis": { "type": "string", "minLength": 1 },
        "comparison_ref": { "type": ["string", "null"] },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "claim_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "finding_code", "severity", "message"],
      "properties": {
        "claim_id": { "$ref": "#/$defs/id" },
        "finding_code": {
          "enum": [
            "UNSUPPORTED_CLAIM",
            "MISSING_COMPARISON",
            "EVIDENCE_BASIS_MISMATCH",
            "ACTUAL_CASH_OVERCLAIM"
          ]
        },
        "severity": { "enum": ["INFO", "WARNING", "ERROR", "BLOCKER"] },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actual_cash",
        "permits_live_order",
        "permits_paper_order",
        "permits_actual_cash",
        "production_exchange_write_used",
        "live_order_submitted",
        "wallet_used",
        "signing_used",
        "llm_api_used"
      ],
      "properties": {
        "actual_cash": { "const": false },
        "permits_live_order": { "const": false },
        "permits_paper_order": { "const": false },
        "permits_actual_cash": { "const": false },
        "production_exchange_write_used": { "const": false },
        "live_order_submitted": { "const": false },
        "wallet_used": { "const": false },
        "signing_used": { "const": false },
        "llm_api_used": { "const": false }
      }
    }
  }
}
