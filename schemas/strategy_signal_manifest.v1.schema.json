{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "generator_id",
    "strategy_id",
    "strategy_family",
    "strategy_version",
    "symbol_bindings",
    "feature_panel_sha256",
    "signal_count",
    "signal_artifact_run_id",
    "signal_artifact_path"
  ],
  "properties": {
    "schema_version": { "const": "strategy_signal_manifest.v1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "generator_id": { "type": "string", "minLength": 1 },
    "strategy_id": { "type": "string", "minLength": 1 },
    "strategy_family": { "type": "string", "minLength": 1 },
    "strategy_version": { "type": "string", "minLength": 1 },
    "symbol_bindings": { "type": "array", "minItems": 1 },
    "feature_panel_sha256": { "type": "string", "minLength": 1 },
    "signal_count": { "type": "integer", "minimum": 0 },
    "signal_artifact_run_id": { "type": "string", "minLength": 1 },
    "signal_artifact_path": { "type": "string", "minLength": 1 },
    "generator_parameters": { "type": "object" }
  },
  "additionalProperties": true
}
