{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/profit_core_adversarial_review.v1.schema.json",
  "title": "profit_core_adversarial_review.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "recorded_at",
    "producer",
    "candidate_id",
    "evidence_packet_ref",
    "review_status",
    "findings",
    "machine_finding_count",
    "manual_finding_count",
    "hard_blocker_count",
    "review_mode",
    "redaction_policy",
    "llm_api_used",
    "external_send_performed",
    "approval_allowed",
    "permission_allowed",
    "paper_execution_allowed",
    "live_allowed",
    "tiny_live_allowed",
    "no_additional_blocker_is_approval",
    "boundary"
  ],
  "properties": {
    "schema_version": { "const": "profit_core_adversarial_review.v1" },
    "review_id": { "$ref": "#/$defs/id" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "command"],
      "properties": {
        "tool": { "const": "sis" },
        "command": { "const": "edge-candidate-adversarial-review-record" }
      }
    },
    "candidate_id": { "$ref": "#/$defs/id" },
    "evidence_packet_ref": { "$ref": "#/$defs/evidence_ref" },
    "review_status": { "$ref": "#/$defs/review_status" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    },
    "machine_finding_count": { "type": "integer", "minimum": 0 },
    "manual_finding_count": { "type": "integer", "minimum": 0 },
    "hard_blocker_count": { "type": "integer", "minimum": 0 },
    "review_mode": { "const": "local_manual_import" },
    "redaction_policy": { "const": "LOCAL_ONLY_NO_EXTERNAL_SEND" },
    "llm_api_used": { "const": false },
    "external_send_performed": { "const": false },
    "approval_allowed": { "const": false },
    "permission_allowed": { "const": false },
    "paper_execution_allowed": { "const": false },
    "live_allowed": { "const": false },
    "tiny_live_allowed": { "const": false },
    "no_additional_blocker_is_approval": { "const": false },
    "boundary": { "$ref": "#/$defs/boundary" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "review_status": {
      "enum": [
        "ADVERSARIAL_FINDING",
        "NEEDS_MORE_EVIDENCE",
        "OVERCLAIM_FLAG",
        "HUMAN_REVIEW_REQUIRED",
        "NO_ADDITIONAL_BLOCKER_FOUND"
      ]
    },
    "evidence_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref_type", "ref_id", "path", "sha256"],
      "properties": {
        "ref_type": {
          "enum": ["evidence_packet", "claim_finding", "claim", "machine_summary"]
        },
        "ref_id": { "type": ["string", "null"], "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
        "path": { "type": ["string", "null"] },
        "sha256": { "type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "status",
        "severity",
        "message",
        "source",
        "evidence_refs",
        "machine_checkable",
        "hard_blocker"
      ],
      "properties": {
        "finding_id": { "$ref": "#/$defs/id" },
        "status": { "$ref": "#/$defs/review_status" },
        "severity": { "enum": ["INFO", "WARNING", "ERROR", "BLOCKER"] },
        "message": { "type": "string", "minLength": 1 },
        "source": { "enum": ["MACHINE_CLAIM_DIFF", "MANUAL_ADVERSARIAL_REVIEW"] },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidence_ref" }
        },
        "machine_checkable": { "type": "boolean" },
        "hard_blocker": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "hard_blocker": { "const": true } } },
          "then": { "properties": { "machine_checkable": { "const": true } } }
        },
        {
          "if": { "properties": { "source": { "const": "MANUAL_ADVERSARIAL_REVIEW" } } },
          "then": {
            "properties": {
              "machine_checkable": { "const": false },
              "hard_blocker": { "const": false }
            }
          }
        }
      ]
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actual_cash_decision_allowed",
        "permits_live_order",
        "permits_paper_order",
        "permits_tiny_live",
        "permits_actual_cash",
        "production_exchange_write_used",
        "live_order_submitted",
        "wallet_used",
        "signing_used",
        "llm_api_used",
        "external_send_performed",
        "gate_override_allowed",
        "strategy_rewrite_allowed",
        "pnl_metric_authority"
      ],
      "properties": {
        "actual_cash_decision_allowed": { "const": false },
        "permits_live_order": { "const": false },
        "permits_paper_order": { "const": false },
        "permits_tiny_live": { "const": false },
        "permits_actual_cash": { "const": false },
        "production_exchange_write_used": { "const": false },
        "live_order_submitted": { "const": false },
        "wallet_used": { "const": false },
        "signing_used": { "const": false },
        "llm_api_used": { "const": false },
        "external_send_performed": { "const": false },
        "gate_override_allowed": { "const": false },
        "strategy_rewrite_allowed": { "const": false },
        "pnl_metric_authority": { "const": false }
      }
    }
  }
}
