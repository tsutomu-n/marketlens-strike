{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_metric_extension.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "framework_id",
    "adapter_role",
    "framework_version",
    "runner_mode",
    "metric_status",
    "reason_codes",
    "dependency_added",
    "engine_run",
    "source_backtest_metrics_path",
    "source_backtest_metrics_hash",
    "returns_series_path",
    "returns_series_hash",
    "frequency",
    "risk_free_rate",
    "return_count",
    "sharpe_ratio",
    "sortino_ratio",
    "max_drawdown",
    "annual_return",
    "annual_volatility",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used"
  ],
  "properties": {
    "schema_version": {"const": "strategy_backtest_metric_extension.v1"},
    "created_at": {"type": "string"},
    "framework_id": {"const": "empyrical_reloaded"},
    "adapter_role": {"type": "string"},
    "framework_version": {"type": ["string", "null"]},
    "runner_mode": {
      "enum": [
        "not_installed_in_current_env",
        "temporary_or_optional_import",
        "installed_without_runner"
      ]
    },
    "metric_status": {"enum": ["completed", "skipped", "failed"]},
    "reason_codes": {"type": "array", "items": {"type": "string"}},
    "dependency_added": {"const": false},
    "engine_run": {"type": "boolean"},
    "source_backtest_metrics_path": {"type": "string"},
    "source_backtest_metrics_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "returns_series_path": {"type": "string"},
    "returns_series_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "frequency": {"enum": ["daily", "weekly", "monthly", "signal"]},
    "risk_free_rate": {"type": "number"},
    "return_count": {"type": "integer", "minimum": 0},
    "sharpe_ratio": {"type": ["number", "null"]},
    "sortino_ratio": {"type": ["number", "null"]},
    "max_drawdown": {"type": ["number", "null"]},
    "annual_return": {"type": ["number", "null"]},
    "annual_volatility": {"type": ["number", "null"]},
    "alpha": {"type": ["number", "null"]},
    "beta": {"type": ["number", "null"]},
    "calmar_ratio": {"type": ["number", "null"]},
    "omega_ratio": {"type": ["number", "null"]},
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false}
  },
  "additionalProperties": false
}
