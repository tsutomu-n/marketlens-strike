{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "crypto_perp_backtest_candidate_pack.v1"},
    "artifact_id": {"type": "string"},
    "created_at": {"type": "string"},
    "producer": {"type": "object"},
    "source_refs": {"type": "array"},
    "boundary": {
      "additionalProperties": false,
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false},
        "live_order_submitted": {"const": false}
      },
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used",
        "live_order_submitted"
      ],
      "type": "object"
    },
    "pack_id": {"type": "string"},
    "decision": {
      "enum": [
        "BACKTEST_REJECT",
        "BACKTEST_REVISE",
        "BACKTEST_COLLECT_MORE_DATA",
        "BACKTEST_CANDIDATE_HOLD"
      ]
    },
    "reason_codes": {"items": {"type": "string"}, "type": "array"},
    "event_count": {"minimum": 0, "type": "integer"},
    "outcome_count": {"minimum": 0, "type": "integer"},
    "artifact_paths": {"additionalProperties": {"type": "string"}, "type": "object"},
    "summary": {"type": "object"},
    "evidence_grade_summary": {
      "additionalProperties": false,
      "properties": {
        "overall_grade": {
          "enum": [
            "insufficient_source_for_local_simulation",
            "local_simulation_with_recomputed_minimal_artifacts",
            "local_simulation_from_existing_artifacts"
          ]
        },
        "strongest_evidence_level": {
          "enum": [
            "incomplete_local_artifact",
            "recomputed_minimal_simulated_estimate",
            "local_simulated_estimate"
          ]
        },
        "basis": {"const": "timestamp_safe_local_simulation"},
        "actual_cash_used": {"const": false},
        "profit_proven": {"const": false},
        "permits_live_order": {"const": false},
        "event_count": {"minimum": 0, "type": "integer"},
        "simulated_trade_count": {"minimum": 0, "type": "integer"},
        "critical_missing_count": {"minimum": 0, "type": "integer"},
        "future_signal_source_count": {"minimum": 0, "type": "integer"},
        "artifact_origin_counts": {"additionalProperties": {"minimum": 0, "type": "integer"}, "type": "object"},
        "source_available_counts": {"additionalProperties": {"minimum": 0, "type": "integer"}, "type": "object"},
        "source_missing_counts": {"additionalProperties": {"minimum": 0, "type": "integer"}, "type": "object"},
        "recomputed_minimal_artifact_count": {"minimum": 0, "type": "integer"},
        "existing_artifact_only": {"type": "boolean"},
        "known_limits": {"items": {"type": "string"}, "type": "array"}
      },
      "required": [
        "overall_grade",
        "strongest_evidence_level",
        "basis",
        "actual_cash_used",
        "profit_proven",
        "permits_live_order",
        "event_count",
        "simulated_trade_count",
        "critical_missing_count",
        "future_signal_source_count",
        "artifact_origin_counts",
        "source_available_counts",
        "source_missing_counts",
        "recomputed_minimal_artifact_count",
        "existing_artifact_only",
        "known_limits"
      ],
      "type": "object"
    },
    "non_goal_flags": {
      "additionalProperties": {"type": "boolean"},
      "properties": {
        "actual_cash_used": {"const": false},
        "profit_proven": {"const": false},
        "actual_cash_readiness_claimed": {"const": false},
        "tiny_live_readiness_claimed": {"const": false},
        "live_trading_readiness_claimed": {"const": false},
        "wallet_or_signing_used": {"const": false},
        "exchange_write_used": {"const": false},
        "live_order_submitted": {"const": false},
        "backtest_promote_to_live_available": {"const": false},
        "ml_or_llm_trade_decision_used": {"const": false}
      },
      "required": [
        "actual_cash_used",
        "profit_proven",
        "actual_cash_readiness_claimed",
        "tiny_live_readiness_claimed",
        "live_trading_readiness_claimed",
        "wallet_or_signing_used",
        "exchange_write_used",
        "live_order_submitted",
        "backtest_promote_to_live_available",
        "ml_or_llm_trade_decision_used"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "artifact_id",
    "created_at",
    "producer",
    "source_refs",
    "boundary",
    "pack_id",
    "decision",
    "reason_codes",
    "event_count",
    "outcome_count",
    "artifact_paths",
    "summary",
    "non_goal_flags"
  ],
  "type": "object"
}
