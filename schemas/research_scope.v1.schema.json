{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Research Scope v1",
  "type": "object",
  "required": ["schema_version", "scope_id", "name", "included", "excluded", "policy"],
  "properties": {
    "schema_version": { "const": "research_scope.v1" },
    "scope_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "included": { "type": "object" },
    "excluded": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "policy": { "type": "object" }
  },
  "additionalProperties": false
}

