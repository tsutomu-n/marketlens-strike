{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ndx_residual_diagnostics.v1.schema.json",
  "type": "object",
  "required": ["schema_version", "dag_id", "dag_artifact_hash", "row_count", "missing_rate", "residual_mean", "residual_std", "neutralized_residuals_path"],
  "properties": {
    "schema_version": {"const": "ndx_residual_diagnostics.v1"},
    "dag_id": {"const": "HYP-NDX-001"},
    "dag_artifact_hash": {"type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$"},
    "row_count": {"type": "integer", "minimum": 1},
    "missing_rate": {"type": "number", "minimum": 0},
    "residual_mean": {"type": "number"},
    "residual_std": {"type": "number"},
    "neutralized_residuals_path": {"type": "string"}
  },
  "additionalProperties": true
}

