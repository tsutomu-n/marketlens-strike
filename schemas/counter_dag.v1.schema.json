{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Counter DAG Registry v1",
  "type": "object",
  "required": ["schema_version", "dag_id", "counter_dags"],
  "properties": {
    "schema_version": { "const": "counter_dag_registry.v1" },
    "dag_id": { "type": "string", "minLength": 1 },
    "counter_dags": { "type": "array", "minItems": 1, "items": { "type": "object" } }
  },
  "additionalProperties": false
}
