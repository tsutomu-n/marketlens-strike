{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core DAG v1",
  "type": "object",
  "required": ["schema_version", "dag_id", "name", "scope_id", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "core_dag.v1" },
    "dag_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "scope_id": { "type": "string", "minLength": 1 },
    "nodes": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "edges": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "forbidden_edges": { "type": "array", "items": { "type": "object" } },
    "counter_dag_refs": { "type": "array", "items": { "type": "string" } },
    "data_requirements": { "type": "array", "items": { "type": "object" } }
  },
  "additionalProperties": false
}

