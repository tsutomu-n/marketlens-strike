{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/profit_core_risk_taker_sprint_isolation.v1.schema.json",
  "title": "profit_core_risk_taker_sprint_isolation.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "isolation_id",
    "recorded_at",
    "producer",
    "protocol_id",
    "candidate_set_id",
    "multiplicity_account_id",
    "mode",
    "output_label",
    "sealed_holdout_window_id",
    "protocol_ref",
    "candidate_set_ref",
    "search_ledger_ref",
    "multiplicity_account_ref",
    "family_count",
    "candidate_count_total",
    "candidate_count_shortlisted",
    "candidate_count_rejected",
    "search_ledger_row_count",
    "generator_types",
    "generator_constraints",
    "default_aggregate_inclusion_allowed",
    "default_aggregate_candidate_count",
    "verification_throughput_reregistration_required",
    "actual_cash_direct_promotion_allowed",
    "tiny_live_direct_promotion_allowed",
    "separate_ledger",
    "separate_holdout",
    "separate_multiplicity_account",
    "promotion_debt",
    "boundary"
  ],
  "properties": {
    "schema_version": { "const": "profit_core_risk_taker_sprint_isolation.v1" },
    "isolation_id": { "$ref": "#/$defs/id" },
    "recorded_at": { "type": "string", "format": "date-time" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool", "command"],
      "properties": {
        "tool": { "const": "sis" },
        "command": { "const": "edge-candidate-risk-taker-sprint-isolation-record" }
      }
    },
    "protocol_id": { "$ref": "#/$defs/id" },
    "candidate_set_id": { "$ref": "#/$defs/id" },
    "multiplicity_account_id": { "$ref": "#/$defs/id" },
    "mode": { "const": "risk_taker_sprint" },
    "output_label": { "const": "SPECULATIVE_SPRINT" },
    "sealed_holdout_window_id": { "$ref": "#/$defs/id" },
    "protocol_ref": { "$ref": "#/$defs/artifact_ref" },
    "candidate_set_ref": { "$ref": "#/$defs/artifact_ref" },
    "search_ledger_ref": { "$ref": "#/$defs/artifact_ref" },
    "multiplicity_account_ref": { "$ref": "#/$defs/artifact_ref" },
    "family_count": { "type": "integer", "minimum": 0 },
    "candidate_count_total": { "type": "integer", "minimum": 0 },
    "candidate_count_shortlisted": { "type": "integer", "minimum": 0 },
    "candidate_count_rejected": { "type": "integer", "minimum": 0 },
    "search_ledger_row_count": { "type": "integer", "minimum": 0 },
    "generator_types": {
      "type": "array",
      "items": {
        "enum": [
          "classical_rule",
          "grammar_based",
          "limited_random",
          "light_ga",
          "ranking_or_no_trade_filter"
        ]
      }
    },
    "generator_constraints": {
      "type": "object",
      "additionalProperties": { "const": "ranking_or_no_trade_filter_only" }
    },
    "default_aggregate_inclusion_allowed": { "const": false },
    "default_aggregate_candidate_count": { "const": 0 },
    "verification_throughput_reregistration_required": { "const": true },
    "actual_cash_direct_promotion_allowed": { "const": false },
    "tiny_live_direct_promotion_allowed": { "const": false },
    "separate_ledger": { "const": true },
    "separate_holdout": { "const": true },
    "separate_multiplicity_account": { "const": true },
    "promotion_debt": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/promotion_debt" }
    },
    "boundary": { "$ref": "#/$defs/boundary" }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "artifact_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_role", "path", "sha256", "schema_version"],
      "properties": {
        "artifact_role": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "schema_version": { "type": ["string", "null"] }
      }
    },
    "promotion_debt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["debt_code", "status", "blocks_actual_cash", "message"],
      "properties": {
        "debt_code": {
          "enum": [
            "RE_REGISTER_UNDER_VERIFICATION_THROUGHPUT",
            "DO_NOT_REUSE_SPRINT_HOLDOUT",
            "ATTACH_DEFAULT_MULTIPLICITY_ACCOUNT",
            "PASS_BACKTEST_KILL_GATE_UNDER_DEFAULT_THRESHOLDS",
            "PASS_VIRTUAL_EXECUTION_GATE_UNDER_DEFAULT_PIPELINE",
            "RISK_TAKER_REVIEW_WITHOUT_LIVE_PERMISSION"
          ]
        },
        "status": { "const": "OUTSTANDING" },
        "blocks_actual_cash": { "const": true },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actual_cash",
        "permits_live_order",
        "permits_paper_order",
        "permits_tiny_live",
        "permits_actual_cash",
        "production_exchange_write_used",
        "live_order_submitted",
        "wallet_used",
        "signing_used",
        "default_aggregate_mixed",
        "sprint_positive_result_promoted"
      ],
      "properties": {
        "actual_cash": { "const": false },
        "permits_live_order": { "const": false },
        "permits_paper_order": { "const": false },
        "permits_tiny_live": { "const": false },
        "permits_actual_cash": { "const": false },
        "production_exchange_write_used": { "const": false },
        "live_order_submitted": { "const": false },
        "wallet_used": { "const": false },
        "signing_used": { "const": false },
        "default_aggregate_mixed": { "const": false },
        "sprint_positive_result_promoted": { "const": false }
      }
    }
  }
}
