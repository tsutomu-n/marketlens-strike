{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "crypto_perp_candidate_leaderboard.v1"
    },
    "artifact_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tool": {
          "const": "sis"
        },
        "command": {
          "const": "crypto-perp-candidate-leaderboard"
        }
      },
      "required": [
        "tool",
        "command"
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "permits_live_order": {
          "const": false
        },
        "live_conversion_allowed": {
          "const": false
        },
        "wallet_used": {
          "const": false
        },
        "signing_used": {
          "const": false
        },
        "exchange_write_used": {
          "const": false
        },
        "live_order_submitted": {
          "const": false
        }
      },
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used",
        "live_order_submitted"
      ]
    },
    "input_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "candidate_id": {
            "type": "string"
          },
          "symbol": {
            "type": "string"
          },
          "timeframe": {
            "type": "string"
          },
          "family": {
            "type": "string"
          },
          "setup_type": {
            "type": "string"
          },
          "ranking_score": {
            "type": "string"
          },
          "source_quality_score": {
            "type": "string"
          },
          "cost_adjusted_total": {
            "type": "string"
          },
          "stress_total": {
            "type": "string"
          },
          "no_trade_delta": {
            "type": "string"
          },
          "executed_trade_count": {
            "type": "integer"
          },
          "win_rate": {
            "type": [
              "string",
              "null"
            ]
          },
          "payoff_ratio": {
            "type": [
              "string",
              "null"
            ]
          },
          "max_drawdown": {
            "type": "string"
          },
          "loss_concentration": {
            "type": "string"
          },
          "profit_concentration": {
            "type": "string"
          },
          "pbo_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "rolling_stability_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "gate_decision": {
            "type": [
              "string",
              "null"
            ]
          },
          "kill_decision": {
            "type": "string"
          },
          "next_action": {
            "enum": [
              "KILL",
              "REVISE_SIGNAL",
              "COLLECT_MORE_DATA",
              "HOLD_FOR_HUMAN_REVIEW"
            ]
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "known_gaps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "rank",
          "candidate_id",
          "symbol",
          "timeframe",
          "family",
          "setup_type",
          "ranking_score",
          "source_quality_score",
          "cost_adjusted_total",
          "stress_total",
          "no_trade_delta",
          "executed_trade_count",
          "win_rate",
          "payoff_ratio",
          "max_drawdown",
          "loss_concentration",
          "profit_concentration",
          "pbo_status",
          "rolling_stability_status",
          "gate_decision",
          "kill_decision",
          "next_action",
          "reason_codes",
          "known_gaps"
        ]
      }
    },
    "summary": {
      "type": "object"
    },
    "known_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "paper_permission_granted": {
      "const": false
    },
    "permits_paper_order": {
      "const": false
    },
    "permits_live_order": {
      "const": false
    },
    "actual_cash_used": {
      "const": false
    },
    "profit_proven": {
      "const": false
    },
    "wallet_used": {
      "const": false
    },
    "signing_used": {
      "const": false
    },
    "exchange_write_used": {
      "const": false
    },
    "live_order_submitted": {
      "const": false
    }
  },
  "required": [
    "schema_version",
    "artifact_id",
    "created_at",
    "producer",
    "source_refs",
    "boundary",
    "input_artifacts",
    "rows",
    "summary",
    "known_gaps",
    "paper_permission_granted",
    "permits_paper_order",
    "permits_live_order",
    "actual_cash_used",
    "profit_proven",
    "wallet_used",
    "signing_used",
    "exchange_write_used",
    "live_order_submitted"
  ]
}
