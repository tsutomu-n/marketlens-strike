{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_external_result.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "source_metrics_path",
    "source_metrics_hash",
    "source_signals_path",
    "source_signals_hash",
    "source_quotes_path",
    "source_quotes_hash",
    "label_horizon_minutes",
    "initial_capital_usd",
    "dependency_added",
    "external_engine_run",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used",
    "results"
  ],
  "properties": {
    "schema_version": {"const": "strategy_backtest_external_result.v1"},
    "created_at": {"type": "string"},
    "source_metrics_path": {"type": "string"},
    "source_metrics_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "source_signals_path": {"type": ["string", "null"]},
    "source_signals_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "source_quotes_path": {"type": ["string", "null"]},
    "source_quotes_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "label_horizon_minutes": {"type": "integer", "minimum": 1},
    "initial_capital_usd": {"type": "number", "minimum": 100, "maximum": 50000},
    "dependency_added": {"const": false},
    "external_engine_run": {"type": "boolean"},
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false},
    "results": {
      "type": "array",
      "items": {"$ref": "#/$defs/external_result"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "method_metrics": {
      "type": "object",
      "required": [
        "trade_count",
        "total_return",
        "max_drawdown",
        "cost_drag_bps",
        "stale_rejected_count",
        "halt_rejected_count"
      ],
      "properties": {
        "trade_count": {"type": ["integer", "null"], "minimum": 0},
        "total_return": {"type": ["number", "null"]},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": ["number", "null"]},
        "stale_rejected_count": {"type": ["integer", "null"], "minimum": 0},
        "halt_rejected_count": {"type": ["integer", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "external_result": {
      "type": "object",
      "required": [
        "framework_id",
        "adapter_role",
        "status",
        "framework_version",
        "runner_mode",
        "run_status",
        "reason_codes",
        "dependency_added",
        "dependency_source",
        "engine_run",
        "permits_live_order",
        "wallet_used",
        "exchange_write_used",
        "metrics"
      ],
      "properties": {
        "framework_id": {
          "enum": [
            "vectorbt",
            "bt",
            "backtesting",
            "zipline_reloaded",
            "backtrader",
            "quantstats",
            "empyrical_reloaded",
            "pyfolio_reloaded",
            "qstrader"
          ]
        },
        "adapter_role": {"type": "string"},
        "status": {"enum": ["installed", "not_installed"]},
        "framework_version": {"type": ["string", "null"]},
        "runner_mode": {
          "enum": [
            "not_installed_in_current_env",
            "temporary_or_optional_import",
            "installed_without_runner"
          ]
        },
        "run_status": {"enum": ["completed", "skipped", "failed"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "dependency_added": {"const": false},
        "dependency_source": {
          "enum": [
            "not_installed_in_current_env",
            "temporary_uv_with",
            "optional_extra_available"
          ]
        },
        "engine_run": {"type": "boolean"},
        "permits_live_order": {"const": false},
        "wallet_used": {"const": false},
        "exchange_write_used": {"const": false},
        "metrics": {"$ref": "#/$defs/method_metrics"}
      },
      "additionalProperties": false
    }
  }
}
