{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "paper_vs_backtest_drift_review.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "strategy_id",
    "created_at",
    "producer",
    "review_status",
    "recommended_action",
    "source_artifacts",
    "drift_metrics",
    "passed_conditions",
    "failed_conditions",
    "warning_conditions",
    "paper_execution_allowed",
    "live_allowed",
    "boundary"
  ],
  "properties": {
    "schema_version": {"const": "paper_vs_backtest_drift_review.v1"},
    "strategy_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": {"const": "sis"},
        "command": {"const": "strategy-drift-review"}
      },
      "additionalProperties": false
    },
    "review_status": {
      "enum": [
        "READY_FOR_HUMAN_DRIFT_REVIEW",
        "NEEDS_RUNTIME_OBSERVATION",
        "NEEDS_BACKTEST_RESULT",
        "BLOCKED_BOUNDARY_VIOLATION"
      ]
    },
    "recommended_action": {
      "enum": [
        "HUMAN_REVIEW_REQUIRED",
        "EXTEND_OBSERVATION",
        "REVISE_STRATEGY",
        "REPAIR_ARTIFACTS"
      ]
    },
    "source_artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_artifact"}
    },
    "backtest_summary": {"$ref": "#/$defs/backtest_summary"},
    "runtime_summary": {"$ref": "#/$defs/runtime_summary"},
    "drift_metrics": {"$ref": "#/$defs/drift_metrics"},
    "passed_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "failed_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "warning_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "paper_execution_allowed": {"const": false},
    "live_allowed": {"const": false},
    "boundary": {"$ref": "#/$defs/boundary"}
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": ["artifact_key", "path", "sha256"],
      "properties": {
        "artifact_key": {"type": "string", "minLength": 1},
        "path": {
          "type": "string",
          "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"
        },
        "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "schema_version": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "backtest_summary": {
      "type": "object",
      "required": [
        "strategy_id",
        "backtest_passed",
        "signals_considered",
        "executed_count",
        "blocked_count",
        "trade_count",
        "total_return"
      ],
      "properties": {
        "strategy_id": {"type": "string"},
        "backtest_passed": {"type": "boolean"},
        "signals_considered": {"type": "integer", "minimum": 0},
        "executed_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "trade_count": {"type": "integer", "minimum": 0},
        "total_return": {"type": "number"},
        "max_drawdown": {"type": ["number", "null"]},
        "win_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "runtime_summary": {
      "type": "object",
      "required": [
        "strategy_id",
        "session_id",
        "source_stage",
        "ingest_status",
        "ledger_entry_count",
        "paper_fill_count",
        "blocked_count",
        "no_fill_count"
      ],
      "properties": {
        "strategy_id": {"type": "string"},
        "session_id": {"type": "string"},
        "source_stage": {"enum": ["paper_smoke", "normal_paper_observation"]},
        "ingest_status": {
          "enum": ["INGESTED", "EMPTY_LEDGER", "BLOCKED_BOUNDARY_VIOLATION"]
        },
        "ledger_entry_count": {"type": "integer", "minimum": 0},
        "paper_fill_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "no_fill_count": {"type": "integer", "minimum": 0},
        "max_observed_spread_bps": {"type": ["number", "null"]},
        "max_observed_quote_age_ms": {"type": ["integer", "null"], "minimum": 0},
        "pnl_available": {"type": "boolean"},
        "pnl_unavailable_reason": {"type": ["string", "null"], "minLength": 1},
        "realized_pnl_usd_total": {"type": ["number", "null"]},
        "gross_pnl_usd_total": {"type": ["number", "null"]},
        "fee_usd_total": {"type": ["number", "null"]},
        "slippage_usd_total": {"type": ["number", "null"]},
        "avg_slippage_bps": {"type": ["number", "null"]},
        "max_abs_slippage_bps": {"type": ["number", "null"], "minimum": 0},
        "avg_fill_price_drift_bps": {"type": ["number", "null"]},
        "max_abs_fill_price_drift_bps": {"type": ["number", "null"], "minimum": 0},
        "filled_notional_usd_total": {"type": ["number", "null"], "minimum": 0},
        "order_lifecycle_counts": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        }
      },
      "additionalProperties": false
    },
    "drift_metrics": {
      "type": "object",
      "required": ["pnl_drift_available"],
      "properties": {
        "runtime_to_backtest_trade_count_ratio": {"type": ["number", "null"]},
        "runtime_blocked_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "runtime_no_fill_rate": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "max_observed_spread_bps": {"type": ["number", "null"]},
        "max_observed_quote_age_ms": {"type": ["integer", "null"], "minimum": 0},
        "pnl_drift_available": {"type": "boolean"},
        "backtest_total_return": {"type": ["number", "null"]},
        "runtime_return_on_filled_notional": {"type": ["number", "null"]},
        "runtime_vs_backtest_return_drift": {"type": ["number", "null"]},
        "runtime_realized_pnl_usd_total": {"type": ["number", "null"]},
        "runtime_fee_usd_total": {"type": ["number", "null"]},
        "runtime_slippage_usd_total": {"type": ["number", "null"]},
        "runtime_avg_slippage_bps": {"type": ["number", "null"]},
        "runtime_max_abs_slippage_bps": {"type": ["number", "null"], "minimum": 0},
        "runtime_avg_fill_price_drift_bps": {"type": ["number", "null"]},
        "runtime_max_abs_fill_price_drift_bps": {"type": ["number", "null"], "minimum": 0}
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": ["condition_id", "passed", "observed", "required", "severity"],
      "properties": {
        "condition_id": {"type": "string", "minLength": 1},
        "passed": {"type": "boolean"},
        "observed": {"type": "string", "minLength": 1},
        "required": {"type": "string", "minLength": 1},
        "severity": {"enum": ["error", "warning"]}
      },
      "additionalProperties": false
    },
    "boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
