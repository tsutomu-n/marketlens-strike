{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_stage_decision.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "strategy_id",
    "created_at",
    "producer",
    "policy_id",
    "policy_hash",
    "selected_stage",
    "selected_profile",
    "decision",
    "source_artifacts",
    "passed_conditions",
    "failed_conditions",
    "warning_conditions",
    "manual_overrides",
    "paper_execution_allowed",
    "live_allowed",
    "boundary"
  ],
  "properties": {
    "schema_version": {"const": "strategy_stage_decision.v1"},
    "strategy_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "created_at": {"type": "string", "format": "date-time"},
    "producer": {
      "type": "object",
      "required": ["tool", "command"],
      "properties": {
        "tool": {"const": "sis"},
        "command": {"const": "strategy-stage-decision"}
      },
      "additionalProperties": false
    },
    "policy_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "policy_hash": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "selected_stage": {
      "enum": ["paper_smoke", "normal_paper_observation", "drift_review", "micro_live_plan"]
    },
    "selected_profile": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "decision": {
      "enum": [
        "BLOCKED",
        "NEEDS_EVIDENCE",
        "READY_FOR_PAPER_SMOKE_PLAN",
        "READY_FOR_NORMAL_PAPER_OBSERVATION",
        "READY_FOR_DRIFT_REVIEW",
        "READY_FOR_MICRO_LIVE_PLAN"
      ]
    },
    "source_artifacts": {
      "type": "array",
      "items": {"$ref": "#/$defs/source_artifact"}
    },
    "passed_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "failed_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "warning_conditions": {
      "type": "array",
      "items": {"$ref": "#/$defs/condition"}
    },
    "manual_overrides": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "paper_evidence_summary": {"$ref": "#/$defs/paper_evidence_summary"},
    "override_reason": {"type": "string", "minLength": 1},
    "reviewer": {"type": "string", "minLength": 1},
    "paper_execution_allowed": {"const": false},
    "live_allowed": {"const": false},
    "boundary": {
      "type": "object",
      "required": [
        "permits_live_order",
        "live_conversion_allowed",
        "wallet_used",
        "signing_used",
        "exchange_write_used"
      ],
      "properties": {
        "permits_live_order": {"const": false},
        "live_conversion_allowed": {"const": false},
        "wallet_used": {"const": false},
        "signing_used": {"const": false},
        "exchange_write_used": {"const": false}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": ["artifact_key", "path", "sha256"],
      "properties": {
        "artifact_key": {"type": "string", "minLength": 1},
        "path": {"type": "string", "pattern": "^(?!/)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.)(?!.*\\\\)(?!.*(?:^|/)(?:credentials|credential|secrets|secret|id_rsa|id_ed25519)(?:/|$)).+"},
        "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
        "schema_version": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "required": ["condition_id", "passed", "observed", "required", "severity"],
      "properties": {
        "condition_id": {"type": "string", "minLength": 1},
        "passed": {"type": "boolean"},
        "observed": {"type": "string", "minLength": 1},
        "required": {"type": "string", "minLength": 1},
        "severity": {"enum": ["error", "warning"]}
      },
      "additionalProperties": false
    },
    "paper_requirement_gap": {
      "type": "object",
      "required": ["observed", "required", "remaining", "met"],
      "properties": {
        "observed": {"type": "integer", "minimum": 0},
        "required": {"type": "integer", "minimum": 0},
        "remaining": {"type": "integer", "minimum": 0},
        "met": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "paper_evidence_summary": {
      "type": "object",
      "required": ["paper_status_present"],
      "properties": {
        "paper_status_present": {"type": "boolean"},
        "smoke_pass_present": {"type": ["boolean", "null"]},
        "smoke_pass_counts_as_normal_pass": {"type": ["boolean", "null"]},
        "normal_thresholds_met": {"type": ["boolean", "null"]},
        "latest_normal_session_id": {"type": ["string", "null"]},
        "normal_fills": {
          "anyOf": [{"$ref": "#/$defs/paper_requirement_gap"}, {"type": "null"}]
        },
        "normal_trading_days": {
          "anyOf": [{"$ref": "#/$defs/paper_requirement_gap"}, {"type": "null"}]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
