{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_authoring_bundle_result.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "paper_only",
    "live_order_submitted",
    "portfolio",
    "aggregate_metrics",
    "best_member",
    "members"
  ],
  "properties": {
    "schema_version": {"const": "strategy_authoring_bundle_result.v1"},
    "bundle_id": {"type": "string"},
    "paper_only": {"const": true},
    "live_order_submitted": {"const": false},
    "portfolio": {
      "type": "object",
      "required": [
        "allocation_method",
        "selection_metric",
        "selection_direction",
        "resolved_selection_direction"
      ],
      "properties": {
        "allocation_method": {"enum": ["fixed_weight", "equal_weight", "risk_parity"]},
        "max_total_allocation_weight": {"type": ["number", "null"], "exclusiveMinimum": 0},
        "selection_metric": {"type": "string"},
        "selection_direction": {"enum": ["maximize", "minimize", "auto"]},
        "resolved_selection_direction": {"enum": ["maximize", "minimize"]}
      },
      "additionalProperties": false
    },
    "aggregate_metrics": {
      "type": "object",
      "required": [
        "member_count",
        "trade_count",
        "weighted_total_return",
        "max_drawdown",
        "cost_drag_bps",
        "multi_leg_group_metrics"
      ],
      "properties": {
        "member_count": {"type": "integer", "minimum": 0},
        "trade_count": {"type": "integer", "minimum": 0},
        "weighted_total_return": {"type": "number"},
        "max_drawdown": {"type": ["number", "null"]},
        "cost_drag_bps": {"type": "number"},
        "multi_leg_group_metrics": {
          "type": "object",
          "required": [
            "member_count",
            "group_count",
            "executed_group_count",
            "complete_group_count",
            "incomplete_group_count",
            "expected_leg_count",
            "executed_leg_count",
            "weighted_total_return",
            "weighted_cost_drag_bps",
            "weighted_avg_group_return",
            "weighted_win_rate",
            "worst_group_return",
            "weighted_max_drawdown",
            "weighted_profit_factor",
            "weighted_avg_leg_return_imbalance",
            "total_notional_usd",
            "weighted_notional_return"
          ],
          "properties": {
            "member_count": {"type": "integer", "minimum": 0},
            "group_count": {"type": "integer", "minimum": 0},
            "executed_group_count": {"type": "integer", "minimum": 0},
            "complete_group_count": {"type": "integer", "minimum": 0},
            "incomplete_group_count": {"type": "integer", "minimum": 0},
            "expected_leg_count": {"type": "integer", "minimum": 0},
            "executed_leg_count": {"type": "integer", "minimum": 0},
            "weighted_total_return": {"type": "number"},
            "weighted_cost_drag_bps": {"type": "number"},
            "weighted_avg_group_return": {"type": ["number", "null"]},
            "weighted_win_rate": {"type": ["number", "null"]},
            "worst_group_return": {"type": ["number", "null"]},
            "weighted_max_drawdown": {"type": ["number", "null"]},
            "weighted_profit_factor": {"type": ["number", "null"]},
            "weighted_avg_leg_return_imbalance": {"type": ["number", "null"]},
            "total_notional_usd": {"type": "number", "minimum": 0},
            "weighted_notional_return": {"type": ["number", "null"]}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "best_member": {"type": ["object", "null"]},
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "member_index",
          "spec_path",
          "strategy_id",
          "allocation_weight",
          "effective_allocation_weight",
          "signal_count",
          "summary"
        ],
        "properties": {
          "member_index": {"type": "integer", "minimum": 0},
          "spec_path": {"type": "string"},
          "strategy_id": {"type": "string"},
          "allocation_weight": {"type": "number", "minimum": 0},
          "effective_allocation_weight": {"type": "number", "minimum": 0},
          "signal_count": {"type": "integer", "minimum": 0},
          "summary": {"type": "object"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
