{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "schema_version": {"const": "strategy_backtest_no_lookahead_diff.v1"},
    "status": {"enum": ["pass", "fail"]},
    "diff_mode": {"type": "string"},
    "source_spec_path": {"type": ["string", "null"]},
    "source_spec_hash": {
      "type": ["string", "null"],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "summary": {
      "type": "object",
      "required": [
        "check_count",
        "failed_count",
        "checked_signal_count",
        "verified_signal_count",
        "unverified_signal_count",
        "coverage_status",
        "false_negative_risk",
        "runtime_future_mutation_replay"
      ],
      "properties": {
        "check_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "checked_signal_count": {"type": "integer", "minimum": 0},
        "verified_signal_count": {"type": "integer", "minimum": 0},
        "unverified_signal_count": {"type": "integer", "minimum": 0},
        "coverage_status": {
          "enum": [
            "insufficient_signal_coverage",
            "runtime_replay_not_applicable",
            "runtime_replay_verified",
            "runtime_replay_failed"
          ]
        },
        "false_negative_risk": {"enum": ["low", "medium", "high"]},
        "runtime_future_mutation_replay": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "checks": {"type": "array"},
    "mutation_scenarios": {"type": "array"},
    "paper_only": {"const": true},
    "live_order_submitted": {"const": false},
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false}
  },
  "required": [
    "schema_version",
    "status",
    "diff_mode",
    "source_spec_path",
    "source_spec_hash",
    "summary",
    "checks",
    "mutation_scenarios",
    "paper_only",
    "live_order_submitted",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used"
  ],
  "type": "object"
}
