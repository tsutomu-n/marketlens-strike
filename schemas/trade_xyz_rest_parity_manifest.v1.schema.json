{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "trade_xyz_rest_parity_manifest.v1",
  "type": "object",
  "required": [
    "schema_version",
    "source",
    "dex",
    "symbols",
    "window_start",
    "window_end",
    "rest_endpoints",
    "ws_manifest_path",
    "comparison_count",
    "missing_ws_symbols",
    "missing_rest_symbols",
    "mismatched_symbols",
    "rate_limit_sleep_seconds",
    "request_error_count",
    "request_count",
    "status",
    "block_reasons"
  ],
  "properties": {
    "schema_version": { "const": "trade_xyz_rest_parity_manifest.v1" },
    "source": { "type": "string" },
    "dex": { "type": "string" },
    "symbols": { "type": "array", "items": { "type": "string" } },
    "window_start": { "type": "string" },
    "window_end": { "type": "string" },
    "rest_endpoints": { "type": "array", "items": { "type": "string" } },
    "ws_manifest_path": { "type": "string" },
    "comparison_count": { "type": "integer", "minimum": 0 },
    "missing_ws_symbols": { "type": "array", "items": { "type": "string" } },
    "missing_rest_symbols": { "type": "array", "items": { "type": "string" } },
    "mismatched_symbols": { "type": "array", "items": { "type": "string" } },
    "rate_limit_sleep_seconds": { "type": "number", "minimum": 0 },
    "request_error_count": { "type": "integer", "minimum": 0 },
    "request_count": { "type": "integer", "minimum": 0 },
    "status": { "type": "string" },
    "block_reasons": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
