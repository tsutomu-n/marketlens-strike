{
  "type": "object",
  "required": [
    "schema_version",
    "candidate_id",
    "strategy_id",
    "execution_venue",
    "execution_symbol",
    "real_market_symbol",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "trade_candidate.v1" },
    "live_order_submitted": { "const": false },
    "stop_loss_bps": { "type": ["number", "null"], "minimum": 0 },
    "min_stop_loss_bps": { "type": ["number", "null"], "minimum": 0 },
    "max_stop_loss_bps": { "type": ["number", "null"], "minimum": 0 },
    "take_profit_bps": { "type": ["number", "null"], "minimum": 0 },
    "min_take_profit_bps": { "type": ["number", "null"], "minimum": 0 },
    "max_take_profit_bps": { "type": ["number", "null"], "minimum": 0 },
    "min_reward_risk_ratio": { "type": ["number", "null"], "minimum": 0 },
    "reward_risk_ratio": { "type": ["number", "null"], "minimum": 0 },
    "trailing_stop_bps": { "type": ["number", "null"], "minimum": 0 },
    "trailing_stop_activation_bps": { "type": ["number", "null"], "minimum": 0 },
    "partial_take_profit_bps": { "type": ["number", "null"], "minimum": 0 },
    "partial_exit_fraction": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "min_holding_minutes": { "type": ["integer", "null"], "minimum": 1 },
    "exit_on_opposite_signal": { "type": "boolean" },
    "bracket_type": { "enum": ["none", "oco"] },
    "bracket_time_stop_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "bracket_break_even_after_bps": { "type": ["number", "null"], "minimum": 0 },
    "bracket_break_even_after_partial_take_profit": { "type": "boolean" },
    "entry_order_type": { "enum": ["market", "limit", "stop_market"] },
    "entry_limit_offset_bps": { "type": ["number", "null"], "minimum": 0 },
    "entry_stop_offset_bps": { "type": ["number", "null"], "minimum": 0 },
    "entry_timeout_minutes": { "type": ["integer", "null"], "minimum": 0 },
    "entry_time_in_force": { "enum": ["gtc", "gtd", "ioc", "fok"] },
    "entry_post_only": { "type": "boolean" },
    "entry_reduce_only": { "type": "boolean" },
    "slippage_bps": { "type": "number", "minimum": 0 },
    "max_fill_fraction": { "type": "number", "minimum": 0, "maximum": 1 },
    "min_fill_fraction": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "max_spread_bps": { "type": ["number", "null"], "minimum": 0 },
    "min_depth_usd": { "type": ["number", "null"], "minimum": 0 },
    "depth_column": { "type": ["string", "null"] },
    "depth_participation_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "max_latency_ms": { "type": ["number", "null"], "minimum": 0 },
    "latency_ms": { "type": ["number", "null"], "minimum": 0 },
    "min_queue_position_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "queue_position_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "min_borrow_availability_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "borrow_availability_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "max_borrow_cost_bps": { "type": ["number", "null"], "minimum": 0 },
    "borrow_cost_bps": { "type": ["number", "null"], "minimum": 0 },
    "max_tax_drag_bps": { "type": ["number", "null"], "minimum": 0 },
    "tax_drag_bps": { "type": ["number", "null"], "minimum": 0 },
    "max_turnover_pressure": { "type": ["number", "null"], "minimum": 0 },
    "turnover_pressure": { "type": ["number", "null"], "minimum": 0 },
    "max_capacity_usage_ratio": { "type": ["number", "null"], "minimum": 0 },
    "capacity_usage_ratio": { "type": ["number", "null"], "minimum": 0 },
    "max_correlation_crowding_score": { "type": ["number", "null"], "minimum": 0 },
    "correlation_crowding_score": { "type": ["number", "null"], "minimum": 0 },
    "min_fee_edge_bps": { "type": ["number", "null"] },
    "fee_edge_bps": { "type": ["number", "null"] },
    "position_weight": { "type": ["number", "null"], "minimum": 0 },
    "notional_usd": { "type": ["number", "null"], "minimum": 0 }
  }
}
