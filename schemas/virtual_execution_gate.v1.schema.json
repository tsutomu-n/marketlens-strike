{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marketlens-strike.local/schemas/virtual_execution_gate.v1.schema.json",
  "title": "virtual_execution_gate.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "gate_id",
    "evaluated_at",
    "candidate_id",
    "mode",
    "gate_state",
    "blocker_codes",
    "lifecycle_events",
    "cash_metric_basis",
    "evidence_basis",
    "actual_cash",
    "permits_live_order",
    "permits_paper_order",
    "permits_actual_cash",
    "production_exchange_write_used",
    "live_order_submitted",
    "wallet_used",
    "signing_used",
    "virtual_pnl_evaluated",
    "artifact_refs",
    "summary"
  ],
  "properties": {
    "schema_version": { "const": "virtual_execution_gate.v1" },
    "gate_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "candidate_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$" },
    "mode": { "enum": ["verification_throughput", "risk_taker_sprint"] },
    "gate_state": {
      "enum": [
        "LOCAL_MOCK_VERIFIED",
        "BLOCKED_BY_CANDIDATE_STATE",
        "BLOCKED_BY_BACKTEST_GATE",
        "BLOCKED_BY_MULTIPLICITY_ACCOUNT",
        "BLOCKED_BY_VIRTUAL_LIFECYCLE",
        "BLOCKED_BY_ARTIFACT_MISMATCH"
      ]
    },
    "blocker_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "lifecycle_events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/lifecycle_event" }
    },
    "cash_metric_basis": { "const": "virtual_exchange" },
    "evidence_basis": { "const": "virtual_exchange" },
    "actual_cash": { "const": false },
    "permits_live_order": { "const": false },
    "permits_paper_order": { "const": false },
    "permits_actual_cash": { "const": false },
    "production_exchange_write_used": { "const": false },
    "live_order_submitted": { "const": false },
    "wallet_used": { "const": false },
    "signing_used": { "const": false },
    "virtual_pnl_evaluated": { "const": false },
    "artifact_refs": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "candidate_set_path",
        "candidate_set_sha256",
        "factory_summary_path",
        "factory_summary_sha256",
        "multiplicity_account_path",
        "multiplicity_account_sha256",
        "backtest_kill_gate_path",
        "backtest_kill_gate_sha256"
      ],
      "properties": {
        "candidate_set_path": { "type": "string", "minLength": 1 },
        "candidate_set_sha256": { "$ref": "#/$defs/sha256" },
        "factory_summary_path": { "type": "string", "minLength": 1 },
        "factory_summary_sha256": { "$ref": "#/$defs/sha256" },
        "multiplicity_account_path": { "type": "string", "minLength": 1 },
        "multiplicity_account_sha256": { "$ref": "#/$defs/sha256" },
        "backtest_kill_gate_path": { "type": "string", "minLength": 1 },
        "backtest_kill_gate_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": {
        "type": ["boolean", "number", "integer", "string"]
      },
      "required": [
        "submit_ack_checked",
        "partial_fill_checked",
        "cancel_checked",
        "duplicate_prevention_checked",
        "flat_reconciliation_checked",
        "profit_evidence"
      ],
      "properties": {
        "submit_ack_checked": { "type": "boolean" },
        "partial_fill_checked": { "type": "boolean" },
        "cancel_checked": { "type": "boolean" },
        "duplicate_prevention_checked": { "type": "boolean" },
        "flat_reconciliation_checked": { "type": "boolean" },
        "submit_reject_reason_checked": { "type": "boolean" },
        "event_count": { "type": "integer", "minimum": 0 },
        "candidate_decision": { "type": "string", "minLength": 1 },
        "backtest_gate_state": { "type": "string", "minLength": 1 },
        "multiplicity_success_only_reporting": { "type": "boolean" },
        "multiplicity_sealed_test_used_for_selection": { "type": "boolean" },
        "unexecutable_reason_count": { "type": "integer", "minimum": 0 },
        "blocker_count": { "type": "integer", "minimum": 0 },
        "profit_evidence": { "const": false }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "lifecycle_event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "order_id"],
      "properties": {
        "event_type": {
          "enum": [
            "SUBMIT_ACK",
            "PARTIAL_FILL",
            "CANCEL_ACK",
            "SUBMIT_REJECTED",
            "RECONCILED_FLAT",
            "UNKNOWN_STATE"
          ]
        },
        "order_id": { "type": "string", "minLength": 1 },
        "filled_quantity": { "type": ["number", "null"], "minimum": 0 },
        "position_after": { "type": ["number", "null"] },
        "reject_reason": { "type": ["string", "null"] }
      }
    }
  }
}
