{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "strategy_backtest_suite_result.v1.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "created_at",
    "paper_only",
    "live_order_submitted",
    "permits_live_order",
    "live_conversion_allowed",
    "wallet_used",
    "exchange_write_used",
    "selection",
    "aggregate",
    "method_matrix",
    "best_run",
    "runs"
  ],
  "properties": {
    "schema_version": {"const": "strategy_backtest_suite_result.v1"},
    "suite_id": {"type": "string"},
    "created_at": {"type": "string"},
    "paper_only": {"const": true},
    "live_order_submitted": {"const": false},
    "permits_live_order": {"const": false},
    "live_conversion_allowed": {"const": false},
    "wallet_used": {"const": false},
    "exchange_write_used": {"const": false},
    "selection": {
      "type": "object",
      "required": ["metric", "direction", "resolved_direction"],
      "properties": {
        "metric": {"type": "string"},
        "direction": {"enum": ["maximize", "minimize", "auto"]},
        "resolved_direction": {"enum": ["maximize", "minimize"]}
      },
      "additionalProperties": false
    },
    "aggregate": {
      "type": "object",
      "required": [
        "run_count",
        "strategy_count",
        "case_count",
        "passed_count",
        "failed_count",
        "trade_count",
        "total_return",
        "cost_drag_bps"
      ],
      "properties": {
        "run_count": {"type": "integer", "minimum": 0},
        "strategy_count": {"type": "integer", "minimum": 0},
        "case_count": {"type": "integer", "minimum": 0},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "trade_count": {"type": "integer", "minimum": 0},
        "total_return": {"type": "number"},
        "cost_drag_bps": {"type": "number"}
      },
      "additionalProperties": false
    },
    "method_matrix": {"$ref": "#/$defs/method_matrix"},
    "best_run": {
      "anyOf": [
        {"$ref": "#/$defs/suite_run"},
        {"type": "null"}
      ]
    },
    "runs": {
      "type": "array",
      "items": {"$ref": "#/$defs/suite_run"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "suite_run": {
      "type": "object",
      "required": [
        "run_id",
        "member_index",
        "case_id",
        "spec_path",
        "strategy_id",
        "signal_count",
        "method_id",
        "method_type",
        "base_method_id",
        "resampling",
        "backtest",
        "summary"
      ],
      "properties": {
        "run_id": {"type": "string"},
        "member_index": {"type": "integer", "minimum": 0},
        "case_id": {"type": "string"},
        "spec_path": {"type": "string"},
        "strategy_id": {"type": "string"},
        "signal_count": {"type": "integer", "minimum": 0},
        "method_id": {"type": "string"},
        "method_type": {"type": "string"},
        "base_method_id": {"type": ["string", "null"]},
        "resampling": {"$ref": "#/$defs/resampling_result"},
        "backtest": {"type": "object"},
        "summary": {"type": "object"}
      },
      "additionalProperties": false
    },
    "method_row": {
      "type": "object",
      "required": [
        "method_id",
        "method_type",
        "base_method_id",
        "resampling_method",
        "split_method",
        "era_unit",
        "case_ids",
        "run_count",
        "passed_count",
        "failed_count"
      ],
      "properties": {
        "method_id": {"type": "string"},
        "method_type": {"type": "string"},
        "base_method_id": {"type": ["string", "null"]},
        "resampling_method": {
          "type": ["string", "null"],
          "enum": ["none", "return_bootstrap", "block_bootstrap", null]
        },
        "split_method": {"type": ["string", "null"]},
        "era_unit": {"type": ["string", "null"]},
        "case_ids": {"type": "array", "items": {"type": "string"}},
        "run_count": {"type": "integer", "minimum": 0},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "resampling_result": {
      "type": "object",
      "required": ["method", "iterations", "seed", "block_size", "status"],
      "properties": {
        "method": {"enum": ["none", "return_bootstrap", "block_bootstrap"]},
        "iterations": {"type": "integer", "minimum": 1},
        "seed": {"type": "integer"},
        "block_size": {"type": "integer", "minimum": 1},
        "status": {"enum": ["not_requested", "completed", "skipped"]},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "source_result_count": {"type": "integer", "minimum": 0},
        "sample_size": {"type": "integer", "minimum": 0},
        "iteration_count": {"type": "integer", "minimum": 0},
        "total_return_min": {"type": "number"},
        "total_return_p05": {"type": "number"},
        "total_return_p50": {"type": "number"},
        "total_return_p95": {"type": "number"},
        "total_return_max": {"type": "number"},
        "positive_total_return_rate": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "method_matrix": {
      "type": "object",
      "required": ["method_count", "counts_by_method", "methods"],
      "properties": {
        "method_count": {"type": "integer", "minimum": 0},
        "counts_by_method": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0}
        },
        "methods": {
          "type": "array",
          "items": {"$ref": "#/$defs/method_row"}
        }
      },
      "additionalProperties": false
    }
  }
}
