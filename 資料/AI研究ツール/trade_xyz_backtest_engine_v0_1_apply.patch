+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+from sis.backtest.engine.fill import resolve_market_fill_price
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+def _row(**overrides: object) -> TradeXyzMarketRow:
+    base = {
+        "ts": datetime(2026, 5, 31, tzinfo=timezone.utc),
+        "symbol": "SP500",
+        "mid_price": 100.0,
+        "spread_bps": 10.0,
+    }
+    base.update(overrides)
+    return TradeXyzMarketRow.model_validate(base)
+
+
+def test_buy_fill_prefers_exec_buy_price() -> None:
+    price = resolve_market_fill_price(_row(exec_buy_price=101.0, best_ask=102.0), "buy")
+
+    assert price.price == 101.0
+    assert price.source == "exec_buy_price"
+
+
+def test_sell_fill_prefers_exec_sell_price() -> None:
+    price = resolve_market_fill_price(_row(exec_sell_price=99.0, best_bid=98.0), "sell")
+
+    assert price.price == 99.0
+    assert price.source == "exec_sell_price"
+
+
+def test_buy_fill_falls_back_to_best_ask() -> None:
+    price = resolve_market_fill_price(_row(best_ask=100.5), "buy")
+
+    assert price.price == 100.5
+    assert price.source == "best_ask"
+
+
+def test_buy_fill_uses_conservative_mid_plus_half_spread() -> None:
+    price = resolve_market_fill_price(_row(), "buy")
+
+    assert round(price.price, 4) == 100.05
+    assert price.source == "mid_plus_half_spread"
+
+
+def test_sell_fill_uses_conservative_mid_minus_half_spread() -> None:
+    price = resolve_market_fill_price(_row(), "sell")
+
+    assert round(price.price, 4) == 99.95
+    assert price.source == "mid_minus_half_spread"
