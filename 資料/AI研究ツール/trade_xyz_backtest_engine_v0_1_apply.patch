diff --git a/src/sis/backtest/trade_xyz/cost_model.py b/src/sis/backtest/trade_xyz/cost_model.py
new file mode 100644
index 0000000..a31ff87
--- /dev/null
+++ b/src/sis/backtest/trade_xyz/cost_model.py
@@ -0,0 +1,103 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Literal
+
+import yaml
+
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+LiquidityFlag = Literal["taker", "maker"]
+
+
+@dataclass(frozen=True)
+class FeeRates:
+    taker_bps: float
+    maker_bps: float
+    mode: str
+    source: str
+
+
+@dataclass(frozen=True)
+class TradeXyzCostModel:
+    fallback_by_mode: dict[str, FeeRates]
+    classification: dict[str, str]
+
+    @classmethod
+    def from_yaml(cls, path: Path) -> "TradeXyzCostModel":
+        payload = yaml.safe_load(path.read_text(encoding="utf-8")) if path.exists() else {}
+        trade_xyz = ((payload or {}).get("fee_model") or {}).get("trade_xyz") or {}
+        fallback_payload = trade_xyz.get("fallback") or {}
+        fallback_by_mode: dict[str, FeeRates] = {}
+        for mode, values in fallback_payload.items():
+            if not isinstance(values, dict):
+                continue
+            taker = values.get("taker_bps")
+            maker = values.get("maker_bps")
+            if isinstance(taker, int | float) and isinstance(maker, int | float):
+                fallback_by_mode[str(mode).lower()] = FeeRates(
+                    taker_bps=float(taker),
+                    maker_bps=float(maker),
+                    mode=str(mode).lower(),
+                    source="config_fallback",
+                )
+        classification_payload = trade_xyz.get("classification") or {}
+        classification = {
+            str(symbol).upper(): str(mode).lower()
+            for symbol, mode in classification_payload.items()
+            if isinstance(symbol, str) and isinstance(mode, str)
+        }
+        return cls(fallback_by_mode=fallback_by_mode, classification=classification)
+
+    @classmethod
+    def observed_only(cls) -> "TradeXyzCostModel":
+        return cls(fallback_by_mode={}, classification={})
+
+    def resolve_fee_rates(self, row: TradeXyzMarketRow) -> FeeRates | None:
+        if row.taker_fee_bps is not None and row.maker_fee_bps is not None:
+            return FeeRates(
+                taker_bps=float(row.taker_fee_bps),
+                maker_bps=float(row.maker_fee_bps),
+                mode=row.fee_mode,
+                source="row_resolved_fee",
+            )
+
+        mode = row.fee_mode if row.fee_mode != "unknown" else self.classification.get(row.symbol)
+        if mode is None:
+            return None
+        return self.fallback_by_mode.get(mode)
+
+    def fee_for_notional(
+        self,
+        *,
+        row: TradeXyzMarketRow,
+        notional: float,
+        liquidity: LiquidityFlag = "taker",
+    ) -> tuple[float, FeeRates]:
+        rates = self.resolve_fee_rates(row)
+        if rates is None:
+            raise ValueError(f"fee rate is unresolved for {row.symbol} at {row.ts.isoformat()}")
+        bps = rates.taker_bps if liquidity == "taker" else rates.maker_bps
+        return abs(float(notional)) * bps / 10_000.0, rates
+
+    def can_enter(self, row: TradeXyzMarketRow) -> bool:
+        return row.entry_allowed_by_market_state and self.resolve_fee_rates(row) is not None
+
+
+def funding_payment(
+    *,
+    position_qty: float,
+    oracle_price: float | None,
+    funding_rate: float | None,
+) -> float:
+    """Return funding cashflow for the row if units are explicitly supplied.
+
+    ``funding_rate`` semantics are intentionally not inferred. Tests/fixtures must
+    define it as a direct period rate. ``None`` means no funding impact in MVP.
+    Positive funding is received by the long position; negative funding is paid.
+    """
+
+    if funding_rate is None or oracle_price is None or position_qty == 0:
+        return 0.0
+    return float(position_qty) * float(oracle_price) * float(funding_rate)
