+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+from sis.backtest.trade_xyz.schema import market_row_from_mapping
+
+
+def test_market_row_from_current_normalized_quote_mapping() -> None:
+    row = market_row_from_mapping(
+        {
+            "ts_client": "2026-05-31T00:00:00+00:00",
+            "canonical_symbol": "sp500",
+            "mark_price": 100.0,
+            "mid_price": 100.1,
+            "index_price": 99.9,
+            "best_bid": 100.0,
+            "best_ask": 100.2,
+            "spread_bps": 2.0,
+            "fee_mode": "standard",
+            "taker_fee_bps": 9.0,
+            "maker_fee_bps": 3.0,
+            "is_tradable": True,
+            "block_reasons": [],
+        }
+    )
+
+    assert row.ts == datetime(2026, 5, 31, 0, 0, tzinfo=timezone.utc)
+    assert row.symbol == "SP500"
+    assert row.close == 100.0
+    assert row.external_price == 99.9
+    assert row.entry_allowed_by_market_state is True
+    assert row.block_reasons == []
+
+
+def test_market_row_blocks_entry_when_reasons_present() -> None:
+    row = market_row_from_mapping(
+        {
+            "ts_client": "2026-05-31T00:00:00+00:00",
+            "canonical_symbol": "SP500",
+            "mid_price": 100.0,
+            "fee_mode": "standard",
+            "taker_fee_bps": 9.0,
+            "maker_fee_bps": 3.0,
+            "is_tradable": True,
+            "block_reasons": ["discovery_bound"],
+        }
+    )
+
+    assert row.entry_allowed_by_market_state is False
+    assert row.block_reasons == ["discovery_bound"]
+
+
+def test_market_row_accepts_list_null_artifact_shape_as_empty_reasons() -> None:
+    row = market_row_from_mapping(
+        {
+            "ts_client": "2026-05-31T00:00:00+00:00",
+            "canonical_symbol": "SP500",
+            "mid_price": 100.0,
+            "block_reasons": [None],
+        }
+    )
+
+    assert row.block_reasons == []
