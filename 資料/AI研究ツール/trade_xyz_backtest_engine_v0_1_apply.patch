+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+import pytest
+
+from sis.backtest.engine.fill import BacktestFill
+from sis.backtest.engine.portfolio import BacktestPortfolio
+
+
+def _fill(side: str, price: float, fee: float, fill_id: str) -> BacktestFill:
+    return BacktestFill(
+        fill_id=fill_id,
+        order_id=f"ORDER-{fill_id}",
+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc),
+        symbol="SP500",
+        side=side,  # type: ignore[arg-type]
+        qty=1.0,
+        fill_price=price,
+        fee=fee,
+        slippage=0.0,
+        liquidity_flag="taker",
+        fill_price_source="fixture",
+    )
+
+
+def test_long_entry_and_exit_accounting_is_net_of_fees() -> None:
+    portfolio = BacktestPortfolio.with_initial_cash(1_000.0)
+
+    entry = portfolio.apply_fill(_fill("buy", 100.0, 1.0, "ENTRY"))
+
+    assert entry.qty == 1.0
+    assert entry.avg_price == 100.0
+    assert entry.fees_paid == 1.0
+    assert entry.realized_pnl == -1.0
+
+    exit_position = portfolio.apply_fill(_fill("sell", 110.0, 1.0, "EXIT"))
+
+    assert exit_position.qty == 0.0
+    assert exit_position.avg_price == 0.0
+    assert exit_position.fees_paid == 2.0
+    assert exit_position.realized_pnl == 8.0
+
+
+def test_sell_more_than_current_position_is_rejected() -> None:
+    portfolio = BacktestPortfolio.with_initial_cash(1_000.0)
+
+    with pytest.raises(ValueError, match="exceeds current long position"):
+        portfolio.apply_fill(_fill("sell", 110.0, 1.0, "EXIT"))
