+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from sis.backtest.trade_xyz.cost_model import TradeXyzCostModel, funding_payment
+from sis.backtest.trade_xyz.schema import market_row_from_mapping
+
+
+def _row(**overrides: object):
+    base = {
+        "ts_client": "2026-05-31T00:00:00+00:00",
+        "canonical_symbol": "SP500",
+        "mid_price": 100.0,
+        "fee_mode": "standard",
+        "taker_fee_bps": None,
+        "maker_fee_bps": None,
+        "is_tradable": True,
+        "block_reasons": [],
+    }
+    base.update(overrides)
+    return market_row_from_mapping(base)
+
+
+def test_cost_model_prefers_row_resolved_fee() -> None:
+    model = TradeXyzCostModel.from_yaml(Path("configs/fee_model.trade_xyz.yaml"))
+    row = _row(taker_fee_bps=8.0, maker_fee_bps=2.0)
+
+    fee, rates = model.fee_for_notional(row=row, notional=10_000.0)
+
+    assert fee == 8.0
+    assert rates.source == "row_resolved_fee"
+
+
+def test_cost_model_uses_config_fallback_for_classified_symbol() -> None:
+    model = TradeXyzCostModel.from_yaml(Path("configs/fee_model.trade_xyz.yaml"))
+    row = _row(fee_mode="unknown", taker_fee_bps=None, maker_fee_bps=None)
+
+    fee, rates = model.fee_for_notional(row=row, notional=10_000.0)
+
+    assert fee == 9.0
+    assert rates.mode == "standard"
+    assert rates.source == "config_fallback"
+
+
+def test_cost_model_rejects_unresolved_fee() -> None:
+    model = TradeXyzCostModel.observed_only()
+    row = _row(fee_mode="unknown", taker_fee_bps=None, maker_fee_bps=None)
+
+    assert model.can_enter(row) is False
+    with pytest.raises(ValueError, match="fee rate is unresolved"):
+        model.fee_for_notional(row=row, notional=10_000.0)
+
+
+def test_funding_payment_is_nullable_and_direct_rate_only() -> None:
+    assert funding_payment(position_qty=1.0, oracle_price=100.0, funding_rate=None) == 0.0
+    assert funding_payment(position_qty=2.0, oracle_price=100.0, funding_rate=-0.001) == -0.2
