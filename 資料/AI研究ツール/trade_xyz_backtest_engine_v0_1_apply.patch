@@ -0,0 +1,33 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import datetime
+from typing import Literal
+
+OrderSide = Literal["buy", "sell"]
+OrderType = Literal["market"]
+
+
+@dataclass(frozen=True)
+class BacktestOrder:
+    """A paper-only order contract for deterministic backtests.
+
+    This is deliberately not the live execution ``OrderIntent`` contract. It has
+    no wallet, signer, nonce, CLOID lifecycle, or exchange write semantics.
+    """
+
+    order_id: str
+    ts: datetime
+    symbol: str
+    side: OrderSide
+    qty: float
+    order_type: OrderType = "market"
+    price: float | None = None
+    reduce_only: bool = False
+    reason: str | None = None
+
+    def __post_init__(self) -> None:
+        if self.qty <= 0:
+            raise ValueError("order qty must be positive")
+        if not self.symbol:
+            raise ValueError("order symbol is required")
diff --git a/src/sis/backtest/engine/portfolio.py b/src/sis/backtest/engine/portfolio.py
new file mode 100644
index 0000000..80e439b
--- /dev/null
+++ b/src/sis/backtest/engine/portfolio.py
@@ -0,0 +1,80 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+
+from sis.backtest.engine.fill import BacktestFill
+
+
+@dataclass
+class BacktestPosition:
+    symbol: str
+    qty: float = 0.0
+    avg_price: float = 0.0
+    realized_pnl: float = 0.0
+    unrealized_pnl: float = 0.0
+    funding_pnl: float = 0.0
+    fees_paid: float = 0.0
+
+    def mark_to_market(self, price: float | None) -> None:
+        if price is None or self.qty == 0:
+            self.unrealized_pnl = 0.0
+            return
+        self.unrealized_pnl = (float(price) - self.avg_price) * self.qty
+
+
+@dataclass
+class BacktestPortfolio:
+    initial_cash: float = 100_000.0
+    cash: float = 100_000.0
+    positions: dict[str, BacktestPosition] = field(default_factory=dict)
+
+    @classmethod
+    def with_initial_cash(cls, initial_cash: float) -> "BacktestPortfolio":
+        return cls(initial_cash=initial_cash, cash=initial_cash)
+
+    def position(self, symbol: str) -> BacktestPosition:
+        if symbol not in self.positions:
+            self.positions[symbol] = BacktestPosition(symbol=symbol)
+        return self.positions[symbol]
+
+    def apply_fill(self, fill: BacktestFill) -> BacktestPosition:
+        if fill.qty <= 0:
+            raise ValueError("fill qty must be positive")
+        pos = self.position(fill.symbol)
+        notional = fill.qty * fill.fill_price
+        pos.fees_paid += fill.fee
+
+        if fill.side == "buy":
+            new_qty = pos.qty + fill.qty
+            if new_qty <= 0:
+                raise ValueError("buy fill produced non-positive long quantity")
+            pos.avg_price = ((pos.avg_price * pos.qty) + notional) / new_qty
+            pos.qty = new_qty
+            pos.realized_pnl -= fill.fee
+            self.cash -= notional + fill.fee
+            return pos
+
+        if fill.qty > pos.qty:
+            raise ValueError("sell fill qty exceeds current long position")
+        gross_pnl = (fill.fill_price - pos.avg_price) * fill.qty
+        pos.realized_pnl += gross_pnl - fill.fee
+        pos.qty -= fill.qty
+        self.cash += notional - fill.fee
+        if pos.qty == 0:
+            pos.avg_price = 0.0
+            pos.unrealized_pnl = 0.0
+        return pos
+
+    def apply_funding(self, symbol: str, amount: float) -> BacktestPosition:
+        pos = self.position(symbol)
+        pos.funding_pnl += amount
+        pos.realized_pnl += amount
+        self.cash += amount
+        return pos
+
+    def mark_to_market(self, symbol: str, price: float | None) -> None:
+        self.position(symbol).mark_to_market(price)
+
+    @property
+    def equity(self) -> float:
+        return self.cash + sum(pos.unrealized_pnl for pos in self.positions.values())
diff --git a/src/sis/backtest/engine/runner.py b/src/sis/backtest/engine/runner.py
new file mode 100644
index 0000000..1747a5a
--- /dev/null
+++ b/src/sis/backtest/engine/runner.py
@@ -0,0 +1,172 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import datetime
+from typing import Literal
+
+from sis.backtest.engine.fill import BacktestFill, make_fill
+from sis.backtest.engine.order import BacktestOrder
+from sis.backtest.engine.portfolio import BacktestPortfolio
+from sis.backtest.trade_xyz.cost_model import TradeXyzCostModel, funding_payment
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+SignalAction = Literal["enter_long", "exit_long"]
+
+
+@dataclass(frozen=True)
+class BacktestSignal:
+    ts: datetime
+    symbol: str
+    action: SignalAction
+    reason: str = "signal"
+
+
+@dataclass(frozen=True)
+class BlockedOrder:
+    ts: datetime
+    symbol: str
+    action: SignalAction
+    reason: str
+
+
+@dataclass
+class BacktestRunResult:
+    orders: list[BacktestOrder] = field(default_factory=list)
+    fills: list[BacktestFill] = field(default_factory=list)
+    blocked_orders: list[BlockedOrder] = field(default_factory=list)
+    equity_curve: list[dict[str, object]] = field(default_factory=list)
+    metrics: dict[str, object] = field(default_factory=dict)
+
+
+def _next_executable_row(
+    rows: list[TradeXyzMarketRow],
+    *,
+    symbol: str,
+    after_ts: datetime,
+) -> TradeXyzMarketRow | None:
+    for row in rows:
+        if row.symbol == symbol and row.ts > after_ts:
+            return row
+    return None
+
+
+def run_signal_backtest(
+    *,
+    rows: list[TradeXyzMarketRow],
+    signals: list[BacktestSignal],
+    cost_model: TradeXyzCostModel,
+    qty: float = 1.0,
+    initial_cash: float = 100_000.0,
+) -> BacktestRunResult:
+    """Run a deterministic long-only, market-like signal backtest.
+
+    Signal timestamps are bar-close decisions. Fills occur only on the next row
+    with ``row.ts > signal.ts`` to prevent same-row lookahead.
+    """
+
+    sorted_rows = sorted(rows, key=lambda row: row.ts)
+    sorted_signals = sorted(signals, key=lambda signal: signal.ts)
+    portfolio = BacktestPortfolio.with_initial_cash(initial_cash)
+    result = BacktestRunResult()
+    order_seq = 0
+    fill_seq = 0
+
+    for signal in sorted_signals:
+        row = _next_executable_row(sorted_rows, symbol=signal.symbol, after_ts=signal.ts)
+        if row is None:
+            result.blocked_orders.append(
+                BlockedOrder(
+                    ts=signal.ts,
+                    symbol=signal.symbol,
+                    action=signal.action,
+                    reason="no_future_executable_row",
+                )
+            )
+            continue
+
+        position = portfolio.position(signal.symbol)
+        if signal.action == "enter_long":
+            if position.qty > 0:
+                result.blocked_orders.append(
+                    BlockedOrder(row.ts, signal.symbol, signal.action, "already_long")
+                )
+                continue
+            if not row.entry_allowed_by_market_state:
+                reason = "market_blocked"
+                if row.block_reasons:
+                    reason = "market_blocked:" + ",".join(row.block_reasons)
+                result.blocked_orders.append(BlockedOrder(row.ts, signal.symbol, signal.action, reason))
+                continue
+            if not cost_model.can_enter(row):
+                result.blocked_orders.append(
+                    BlockedOrder(row.ts, signal.symbol, signal.action, "fee_unresolved")
+                )
+                continue
+            side = "buy"
+            reduce_only = False
+            order_qty = qty
+        else:
+            if position.qty <= 0:
+                result.blocked_orders.append(
+                    BlockedOrder(row.ts, signal.symbol, signal.action, "no_long_position")
+                )
+                continue
+            side = "sell"
+            reduce_only = True
+            order_qty = position.qty
+
+        order_seq += 1
+        order = BacktestOrder(
+            order_id=f"ORDER-{order_seq:06d}",
+            ts=row.ts,
+            symbol=signal.symbol,
+            side=side,
+            qty=order_qty,
+            reduce_only=reduce_only,
+            reason=signal.reason,
+        )
+        # fee is calculated from the resolved fill notional. Resolve price once via make_fill with zero
+        # fee, then recalculate the fee and construct the final fill.
+        provisional = make_fill(order=order, row=row, fee=0.0, fill_sequence=fill_seq + 1)
+        fee, _rates = cost_model.fee_for_notional(row=row, notional=provisional.notional)
+        fill_seq += 1
+        fill = make_fill(order=order, row=row, fee=fee, fill_sequence=fill_seq)
+        portfolio.apply_fill(fill)
+        funding = funding_payment(
+            position_qty=portfolio.position(signal.symbol).qty,
+            oracle_price=row.oracle_price,
+            funding_rate=row.funding_rate,
+        )
+        if funding:
+            portfolio.apply_funding(signal.symbol, funding)
+        mark = row.close_or_mark
+        if mark is not None:
+            portfolio.mark_to_market(signal.symbol, mark)
+        result.orders.append(order)
+        result.fills.append(fill)
+        result.equity_curve.append(
+            {
+                "ts": row.ts.isoformat(),
+                "symbol": signal.symbol,
+                "equity": portfolio.equity,
+                "cash": portfolio.cash,
+                "position_qty": portfolio.position(signal.symbol).qty,
+                "realized_pnl": portfolio.position(signal.symbol).realized_pnl,
+            }
+        )
+
+    total_fees = sum(fill.fee for fill in result.fills)
+    position_values = list(portfolio.positions.values())
+    net_pnl = sum(pos.realized_pnl + pos.unrealized_pnl for pos in position_values)
+    result.metrics = {
+        "order_count": len(result.orders),
+        "fill_count": len(result.fills),
+        "blocked_order_count": len(result.blocked_orders),
+        "fees_paid": total_fees,
+        "net_pnl": net_pnl,
+        "final_equity": portfolio.equity,
+        "wallet_used": False,
+        "exchange_write_used": False,
+        "no_live_order": True,
+    }
+    return result
