+from __future__ import annotations
+
+from datetime import datetime, timezone
+from typing import Any
+
+from pydantic import BaseModel, ConfigDict, field_validator
+
+
+class TradeXyzMarketRow(BaseModel):
+    """Point-in-time Trade[XYZ] market row used by the pure backtest engine."""
+
+    model_config = ConfigDict(extra="ignore")
+
+    ts: datetime
+    symbol: str
+    open: float | None = None
+    high: float | None = None
+    low: float | None = None
+    close: float | None = None
+    volume: float | None = None
+    mid_price: float | None = None
+    mark_price: float | None = None
+    oracle_price: float | None = None
+    external_price: float | None = None
+    exec_buy_price: float | None = None
+    exec_sell_price: float | None = None
+    best_bid: float | None = None
+    best_ask: float | None = None
+    bid_price: float | None = None
+    ask_price: float | None = None
+    funding_rate: float | None = None
+    funding_interval_minutes: int | None = None
+    spread_bps: float | None = None
+    taker_fee_bps: float | None = None
+    maker_fee_bps: float | None = None
+    fee_mode: str = "unknown"
+    session_type: str = "unknown"
+    discovery_bound_pct: float | None = None
+    oi_cap_usage: float | None = None
+    is_tradable: bool = True
+    block_reasons: list[str] = []
+
+    @field_validator("ts", mode="before")
+    @classmethod
+    def _parse_ts(cls, value: object) -> datetime:
+        if isinstance(value, datetime):
+            dt = value
+        elif isinstance(value, str):
+            dt = datetime.fromisoformat(value.replace("Z", "+00:00"))
+        else:
+            raise ValueError("ts must be datetime or ISO string")
+        if dt.tzinfo is None:
+            return dt.replace(tzinfo=timezone.utc)
+        return dt.astimezone(timezone.utc)
+
+    @field_validator("symbol", mode="before")
+    @classmethod
+    def _normalize_symbol(cls, value: object) -> str:
+        symbol = str(value or "").strip().upper()
+        if not symbol:
+            raise ValueError("symbol is required")
+        return symbol
+
+    @field_validator("fee_mode", mode="before")
+    @classmethod
+    def _normalize_fee_mode(cls, value: object) -> str:
+        mode = str(value or "unknown").strip().lower()
+        return mode or "unknown"
+
+    @field_validator("session_type", mode="before")
+    @classmethod
+    def _normalize_session_type(cls, value: object) -> str:
+        session_type = str(value or "unknown").strip().lower()
+        return session_type or "unknown"
+
+    @field_validator("block_reasons", mode="before")
+    @classmethod
+    def _normalize_block_reasons(cls, value: object) -> list[str]:
+        if value is None:
+            return []
+        if isinstance(value, list):
+            return [str(item) for item in value if item is not None and str(item)]
+        if isinstance(value, tuple):
+            return [str(item) for item in value if item is not None and str(item)]
+        if isinstance(value, str):
+            return [value] if value else []
+        return []
+
+    @property
+    def entry_allowed_by_market_state(self) -> bool:
+        return self.is_tradable and not self.block_reasons
+
+    @property
+    def close_or_mark(self) -> float | None:
+        return _first_float(self.close, self.mark_price, self.mid_price, self.oracle_price, self.external_price)
+
+
+def _first_float(*values: object) -> float | None:
+    for value in values:
+        if value is None or value == "":
+            continue
+        if not isinstance(value, int | float | str):
+            continue
+        try:
+            number = float(value)
+        except ValueError:
+            continue
+        if number > 0:
+            return number
+    return None
+
+
+def _get(row: dict[str, Any], *keys: str) -> Any:
+    for key in keys:
+        if key in row:
+            return row[key]
+    return None
+
+
+def market_row_from_mapping(row: dict[str, Any]) -> TradeXyzMarketRow:
+    """Build a Trade[XYZ] market row from current normalized quote/bar mappings."""
+
+    ts = _get(row, "ts", "ts_client", "timestamp")
+    symbol = _get(row, "symbol", "canonical_symbol", "coin")
+    payload = {
+        "ts": ts,
+        "symbol": symbol,
+        "open": _get(row, "open"),
+        "high": _get(row, "high"),
+        "low": _get(row, "low"),
+        "close": _get(row, "close", "mark_price", "mid_price"),
+        "volume": _get(row, "volume", "day_notional_volume"),
+        "mid_price": _get(row, "mid_price"),
+        "mark_price": _get(row, "mark_price"),
+        "oracle_price": _get(row, "oracle_price"),
+        "external_price": _get(row, "external_price", "index_price"),
+        "exec_buy_price": _get(row, "exec_buy_price"),
+        "exec_sell_price": _get(row, "exec_sell_price"),
+        "best_bid": _get(row, "best_bid"),
+        "best_ask": _get(row, "best_ask"),
+        "bid_price": _get(row, "bid_price"),
+        "ask_price": _get(row, "ask_price"),
+        "funding_rate": _get(row, "funding_rate"),
+        "funding_interval_minutes": _get(row, "funding_interval_minutes"),
+        "spread_bps": _get(row, "spread_bps"),
+        "taker_fee_bps": _get(row, "taker_fee_bps"),
+        "maker_fee_bps": _get(row, "maker_fee_bps"),
+        "fee_mode": _get(row, "fee_mode"),
+        "session_type": _get(row, "session_type"),
+        "discovery_bound_pct": _get(row, "discovery_bound_pct"),
+        "oi_cap_usage": _get(row, "oi_cap_usage"),
+        "is_tradable": bool(_get(row, "is_tradable") if _get(row, "is_tradable") is not None else True),
+        "block_reasons": _get(row, "block_reasons"),
+    }
+    return TradeXyzMarketRow.model_validate(payload)
