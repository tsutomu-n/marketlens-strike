+"""Pure backtest engine contracts.
+
+This package is intentionally separate from the existing Strategy Lab bridge in
+``sis.backtest.bridge``. It does not know about wallets, signing, live exchange
+writes, nonces, or CLOIDs.
+"""
+
+from sis.backtest.engine.order import BacktestOrder
+from sis.backtest.engine.fill import BacktestFill
+from sis.backtest.engine.portfolio import BacktestPortfolio, BacktestPosition
+
+__all__ = ["BacktestOrder", "BacktestFill", "BacktestPortfolio", "BacktestPosition"]
diff --git a/src/sis/backtest/engine/fill.py b/src/sis/backtest/engine/fill.py
new file mode 100644
index 0000000..64786dd
--- /dev/null
+++ b/src/sis/backtest/engine/fill.py
@@ -0,0 +1,123 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import datetime
+from typing import Protocol
+
+from sis.backtest.engine.order import BacktestOrder, OrderSide
+
+
+class MarketRowLike(Protocol):
+    ts: datetime
+    symbol: str
+    exec_buy_price: float | None
+    exec_sell_price: float | None
+    best_ask: float | None
+    best_bid: float | None
+    ask_price: float | None
+    bid_price: float | None
+    mid_price: float | None
+    spread_bps: float | None
+
+
+@dataclass(frozen=True)
+class BacktestFill:
+    fill_id: str
+    order_id: str
+    ts: datetime
+    symbol: str
+    side: OrderSide
+    qty: float
+    fill_price: float
+    fee: float
+    slippage: float
+    liquidity_flag: str
+    fill_price_source: str
+
+    @property
+    def notional(self) -> float:
+        return self.qty * self.fill_price
+
+
+@dataclass(frozen=True)
+class FillPrice:
+    price: float
+    source: str
+    slippage: float = 0.0
+
+
+def _positive(value: float | None) -> float | None:
+    if value is None:
+        return None
+    if value <= 0:
+        return None
+    return float(value)
+
+
+def resolve_market_fill_price(row: MarketRowLike, side: OrderSide) -> FillPrice:
+    """Resolve a conservative market-like fill price for one row.
+
+    Long entry / buy side preference:
+    ``exec_buy_price`` -> ``best_ask`` -> ``ask_price`` -> conservative
+    ``mid_price`` plus half spread.
+
+    Long exit / sell side preference:
+    ``exec_sell_price`` -> ``best_bid`` -> ``bid_price`` -> conservative
+    ``mid_price`` minus half spread.
+    """
+
+    if side == "buy":
+        candidates = [
+            (row.exec_buy_price, "exec_buy_price"),
+            (row.best_ask, "best_ask"),
+            (row.ask_price, "ask_price"),
+        ]
+        for value, source in candidates:
+            price = _positive(value)
+            if price is not None:
+                return FillPrice(price=price, source=source)
+        mid = _positive(row.mid_price)
+        if mid is not None:
+            spread_bps = max(float(row.spread_bps or 0.0), 0.0)
+            estimated = mid * (1.0 + spread_bps / 20_000.0)
+            return FillPrice(price=estimated, source="mid_plus_half_spread", slippage=estimated - mid)
+    else:
+        candidates = [
+            (row.exec_sell_price, "exec_sell_price"),
+            (row.best_bid, "best_bid"),
+            (row.bid_price, "bid_price"),
+        ]
+        for value, source in candidates:
+            price = _positive(value)
+            if price is not None:
+                return FillPrice(price=price, source=source)
+        mid = _positive(row.mid_price)
+        if mid is not None:
+            spread_bps = max(float(row.spread_bps or 0.0), 0.0)
+            estimated = mid * (1.0 - spread_bps / 20_000.0)
+            return FillPrice(price=estimated, source="mid_minus_half_spread", slippage=mid - estimated)
+
+    raise ValueError(f"cannot resolve market fill price for {row.symbol} at {row.ts.isoformat()}")
+
+
+def make_fill(
+    *,
+    order: BacktestOrder,
+    row: MarketRowLike,
+    fee: float,
+    fill_sequence: int,
+) -> BacktestFill:
+    fill_price = resolve_market_fill_price(row, order.side)
+    return BacktestFill(
+        fill_id=f"FILL-{fill_sequence:06d}",
+        order_id=order.order_id,
+        ts=row.ts,
+        symbol=order.symbol,
+        side=order.side,
+        qty=order.qty,
+        fill_price=fill_price.price,
+        fee=fee,
+        slippage=fill_price.slippage,
+        liquidity_flag="taker",
+        fill_price_source=fill_price.source,
+    )
