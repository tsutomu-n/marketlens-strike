@@ -0,0 +1,79 @@
+from __future__ import annotations
+
+from datetime import datetime, timezone
+from pathlib import Path
+
+from sis.backtest.engine.runner import BacktestSignal, run_signal_backtest
+from sis.backtest.trade_xyz.cost_model import TradeXyzCostModel
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+def _row(hour: int, price: float, *, tradable: bool = True, fee_mode: str = "standard") -> TradeXyzMarketRow:
+    return TradeXyzMarketRow.model_validate(
+        {
+            "ts": datetime(2026, 5, 31, hour, tzinfo=timezone.utc),
+            "symbol": "SP500",
+            "mid_price": price,
+            "mark_price": price,
+            "oracle_price": price,
+            "best_ask": price,
+            "best_bid": price,
+            "spread_bps": 1.0,
+            "fee_mode": fee_mode,
+            "taker_fee_bps": 9.0 if fee_mode != "unknown" else None,
+            "maker_fee_bps": 3.0 if fee_mode != "unknown" else None,
+            "is_tradable": tradable,
+            "block_reasons": [] if tradable else ["fixture_block"],
+        }
+    )
+
+
+def _model() -> TradeXyzCostModel:
+    return TradeXyzCostModel.from_yaml(Path("configs/fee_model.trade_xyz.yaml"))
+
+
+def test_signal_fills_on_next_row_not_same_row() -> None:
+    rows = [_row(0, 100.0), _row(1, 101.0), _row(2, 9999.0)]
+    signals = [BacktestSignal(ts=rows[0].ts, symbol="SP500", action="enter_long")]
+
+    result = run_signal_backtest(rows=rows, signals=signals, cost_model=_model())
+
+    assert len(result.fills) == 1
+    assert result.fills[0].ts == rows[1].ts
+    assert result.fills[0].fill_price == 101.0
+
+
+def test_changing_future_bar_after_fill_does_not_change_prior_fill() -> None:
+    signals = [BacktestSignal(ts=datetime(2026, 5, 31, 0, tzinfo=timezone.utc), symbol="SP500", action="enter_long")]
+    first = run_signal_backtest(
+        rows=[_row(0, 100.0), _row(1, 101.0), _row(2, 200.0)],
+        signals=signals,
+        cost_model=_model(),
+    )
+    second = run_signal_backtest(
+        rows=[_row(0, 100.0), _row(1, 101.0), _row(2, 9999.0)],
+        signals=signals,
+        cost_model=_model(),
+    )
+
+    assert first.fills[0].fill_price == second.fills[0].fill_price == 101.0
+
+
+def test_blocked_market_row_prevents_new_entry() -> None:
+    rows = [_row(0, 100.0), _row(1, 101.0, tradable=False)]
+    signals = [BacktestSignal(ts=rows[0].ts, symbol="SP500", action="enter_long")]
+
+    result = run_signal_backtest(rows=rows, signals=signals, cost_model=_model())
+
+    assert result.fills == []
+    assert result.blocked_orders[0].reason == "market_blocked:fixture_block"
+
+
+def test_unresolved_fee_prevents_new_entry() -> None:
+    rows = [_row(0, 100.0), _row(1, 101.0, fee_mode="unknown")]
+    signals = [BacktestSignal(ts=rows[0].ts, symbol="SP500", action="enter_long")]
+
+    result = run_signal_backtest(rows=rows, signals=signals, cost_model=TradeXyzCostModel.observed_only())
+
+    assert result.fills == []
+    assert result.blocked_orders[0].reason == "fee_unresolved"
