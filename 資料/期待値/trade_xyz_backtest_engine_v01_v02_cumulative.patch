+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc),
+        symbol="SP500",
+        **kwargs,
+    )
+
+
+def test_fill_model_prefers_explicit_exec_prices() -> None:
+    row = _row(
+        exec_buy_price=101.0,
+        exec_sell_price=99.0,
+        best_ask=102.0,
+        best_bid=98.0,
+        mid_price=100.0,
+    )
+
+    assert resolve_market_fill_price(row, OrderSide.BUY) == (101.0, "exec_buy_price")
+    assert resolve_market_fill_price(row, OrderSide.SELL) == (99.0, "exec_sell_price")
+
+
+def test_fill_model_uses_conservative_mid_spread_fallback() -> None:
+    row = _row(mid_price=100.0, spread_bps=10.0)
+
+    assert resolve_market_fill_price(row, OrderSide.BUY) == (100.05, "mid_plus_half_spread")
+    assert resolve_market_fill_price(row, OrderSide.SELL) == (99.95, "mid_minus_half_spread")
+
+
+def test_create_market_fill_calculates_fee() -> None:
+    row = _row(exec_buy_price=100.0)
+    order = BacktestOrder(
+        order_id="order-1",
+        ts=row.ts,
+        symbol="SP500",
+        side=OrderSide.BUY,
+        qty=2.0,
+    )
+
+    fill = create_market_fill(order=order, row=row, fee_bps=9.0)
+
+    assert fill.fill_price == 100.0
+    assert fill.fee_usd == pytest.approx(0.18)
+    assert fill.liquidity_flag == "taker"
+
+
+def test_fill_model_requires_price() -> None:
+    row = _row()
+    with pytest.raises(FillModelError):
+        resolve_market_fill_price(row, OrderSide.BUY)
