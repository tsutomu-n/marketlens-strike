+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import datetime
+from enum import StrEnum
+
+
+class OrderSide(StrEnum):
+    BUY = "buy"
+    SELL = "sell"
+
+
+class OrderType(StrEnum):
+    MARKET = "market"
+
+
+@dataclass(frozen=True)
+class BacktestOrder:
+    """Wallet-free, exchange-write-free backtest order contract."""
+
+    order_id: str
+    ts: datetime
+    symbol: str
+    side: OrderSide
+    qty: float
+    order_type: OrderType = OrderType.MARKET
+    reduce_only: bool = False
+    client_order_id: str | None = None
+
+    def __post_init__(self) -> None:
+        if not self.order_id:
+            raise ValueError("order_id must be non-empty")
+        if not self.symbol.strip():
+            raise ValueError("symbol must be non-empty")
+        if self.qty <= 0:
+            raise ValueError("qty must be positive")
diff --git a/src/sis/backtest/engine/portfolio.py b/src/sis/backtest/engine/portfolio.py
new file mode 100644
index 0000000..67b12cd
--- /dev/null
+++ b/src/sis/backtest/engine/portfolio.py
@@ -0,0 +1,114 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+
+from sis.backtest.engine.fill import BacktestFill
+from sis.backtest.engine.order import OrderSide
+
+
+@dataclass
+class PositionState:
+    symbol: str
+    qty: float = 0.0
+    avg_price: float = 0.0
+    realized_pnl: float = 0.0
+    funding_pnl: float = 0.0
+    fees_paid: float = 0.0
+    open_entry_fees: float = 0.0
+    open_funding_pnl: float = 0.0
+
+    def market_value(self, mark_price: float | None) -> float:
+        if mark_price is None:
+            return 0.0
+        return self.qty * mark_price
+
+
+@dataclass
+class BacktestPortfolio:
+    """Long-only accounting ledger for the first Trade[XYZ] BT slice."""
+
+    initial_cash: float
+    cash: float | None = None
+    positions: dict[str, PositionState] = field(default_factory=dict)
+    closed_trade_pnls: list[float] = field(default_factory=list)
+
+    def __post_init__(self) -> None:
+        if self.initial_cash <= 0:
+            raise ValueError("initial_cash must be positive")
+        if self.cash is None:
+            self.cash = self.initial_cash
+
+    def position(self, symbol: str) -> PositionState:
+        normalized = symbol.upper()
+        if normalized not in self.positions:
+            self.positions[normalized] = PositionState(symbol=normalized)
+        return self.positions[normalized]
+
+    def apply_fill(self, fill: BacktestFill) -> PositionState:
+        position = self.position(fill.symbol)
+        notional = fill.notional_usd
+        position.fees_paid += fill.fee_usd
+
+        if fill.side == OrderSide.BUY:
+            if self.cash is None:
+                raise ValueError("cash is not initialized")
+            new_qty = position.qty + fill.qty
+            if new_qty <= 0:
+                raise ValueError("buy fill would not create a positive position")
+            position.avg_price = (
+                (position.avg_price * position.qty) + (fill.fill_price * fill.qty)
+            ) / new_qty
+            position.qty = new_qty
+            position.open_entry_fees += fill.fee_usd
+            self.cash -= notional + fill.fee_usd
+            return position
+
+        if fill.qty > position.qty:
+            raise ValueError("sell fill exceeds long position quantity")
+        if position.qty <= 0:
+            raise ValueError("sell fill requires a long position")
+
+        close_fraction = fill.qty / position.qty
+        allocated_entry_fee = position.open_entry_fees * close_fraction
+        allocated_funding = position.open_funding_pnl * close_fraction
+        gross_pnl = (fill.fill_price - position.avg_price) * fill.qty
+        realized = gross_pnl - allocated_entry_fee - fill.fee_usd + allocated_funding
+        position.realized_pnl += realized
+        position.qty -= fill.qty
+        position.open_entry_fees -= allocated_entry_fee
+        position.open_funding_pnl -= allocated_funding
+        if self.cash is None:
+            raise ValueError("cash is not initialized")
+        self.cash += notional - fill.fee_usd
+        self.closed_trade_pnls.append(realized)
+        if position.qty == 0:
+            position.avg_price = 0.0
+            position.open_entry_fees = 0.0
+            position.open_funding_pnl = 0.0
+        return position
+
+    def apply_funding(self, symbol: str, cashflow_usd: float) -> PositionState:
+        position = self.position(symbol)
+        if position.qty == 0 or cashflow_usd == 0:
+            return position
+        if self.cash is None:
+            raise ValueError("cash is not initialized")
+        self.cash += cashflow_usd
+        position.funding_pnl += cashflow_usd
+        position.open_funding_pnl += cashflow_usd
+        return position
+
+    def equity(self, mark_prices: dict[str, float | None] | None = None) -> float:
+        value = self.cash if self.cash is not None else 0.0
+        marks = mark_prices or {}
+        for symbol, position in self.positions.items():
+            value += position.market_value(marks.get(symbol))
+        return value
+
+    @property
+    def fees_paid(self) -> float:
+        return sum(position.fees_paid for position in self.positions.values())
+
+    @property
+    def funding_pnl(self) -> float:
+        return sum(position.funding_pnl for position in self.positions.values())
diff --git a/src/sis/backtest/engine/runner.py b/src/sis/backtest/engine/runner.py
new file mode 100644
index 0000000..e377bec
--- /dev/null
+++ b/src/sis/backtest/engine/runner.py
@@ -0,0 +1,240 @@
+from __future__ import annotations
+
+from dataclasses import dataclass, field
+from datetime import datetime
+
+from sis.backtest.engine.fill import BacktestFill, create_market_fill
+from sis.backtest.engine.metrics import BacktestMetricSummary, summarize_metrics
+from sis.backtest.engine.order import BacktestOrder, OrderSide
+from sis.backtest.engine.portfolio import BacktestPortfolio
+from sis.backtest.trade_xyz.cost_model import FeeResolutionError, resolve_taker_fee_bps
+from sis.backtest.trade_xyz.funding import funding_cashflow_usd
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+@dataclass(frozen=True)
+class EquitySnapshot:
+    ts: datetime
+    symbol: str
+    equity: float
+    cash: float
+    position_qty: float
+    avg_price: float
+    valuation_price: float | None
+    valuation_price_source: str | None
+    mark_price: float | None
+    oracle_price: float | None
+    external_price: float | None
+    mark_oracle_basis_bps: float | None
+    funding_pnl: float
+    fees_paid: float
+    session_type: str | None
+    market_status: str | None
+
+
+@dataclass(frozen=True)
+class BacktestRunResult:
+    orders: list[BacktestOrder]
+    fills: list[BacktestFill]
+    equity_curve: list[float]
+    equity_snapshots: list[EquitySnapshot]
+    blocked_entries: dict[str, int]
+    session_breakdown: dict[str, int]
+    market_status_breakdown: dict[str, int]
+    metrics: BacktestMetricSummary
+
+
+@dataclass(frozen=True)
+class BreakoutConfig:
+    symbol: str
+    entry_lookback: int = 20
+    exit_lookback: int = 10
+    qty: float = 1.0
+    initial_cash: float = 10_000.0
+    fee_model: dict = field(default_factory=dict)
+
+    def __post_init__(self) -> None:
+        if self.entry_lookback <= 0 or self.exit_lookback <= 0:
+            raise ValueError("lookbacks must be positive")
+        if self.qty <= 0:
+            raise ValueError("qty must be positive")
+
+
+def _count_key(counter: dict[str, int], value: str | None) -> None:
+    key = value or "unknown"
+    counter[key] = counter.get(key, 0) + 1
+
+
+def _basis_bps(numerator: float | None, denominator: float | None) -> float | None:
+    if numerator is None or denominator is None or denominator <= 0:
+        return None
+    return (numerator / denominator - 1.0) * 10_000
+
+
+def _valuation_price(row: TradeXyzMarketRow) -> tuple[float | None, str | None]:
+    for value, source in (
+        (row.mark_price, "mark_price"),
+        (row.mid_price, "mid_price"),
+        (row.close, "close"),
+        (row.oracle_price, "oracle_price"),
+        (row.index_price, "index_price"),
+    ):
+        if value is not None and value > 0:
+            return value, source
+    return None, None
+
+
+def _snapshot(
+    *, row: TradeXyzMarketRow, portfolio: BacktestPortfolio, symbol: str
+) -> EquitySnapshot:
+    position = portfolio.position(symbol)
+    valuation_price, source = _valuation_price(row)
+    equity = portfolio.equity({symbol: valuation_price})
+    return EquitySnapshot(
+        ts=row.ts,
+        symbol=symbol,
+        equity=equity,
+        cash=portfolio.cash if portfolio.cash is not None else 0.0,
+        position_qty=position.qty,
+        avg_price=position.avg_price,
+        valuation_price=valuation_price,
+        valuation_price_source=source,
+        mark_price=row.mark_price,
+        oracle_price=row.oracle_price,
+        external_price=row.external_price,
+        mark_oracle_basis_bps=_basis_bps(row.mark_price, row.oracle_price),
+        funding_pnl=position.funding_pnl,
+        fees_paid=position.fees_paid,
+        session_type=row.session_type,
+        market_status=row.market_status,
+    )
+
+
+def _try_resolve_entry_fee(
+    row: TradeXyzMarketRow,
+    *,
+    fee_model: dict,
+    blocked_entries: dict[str, int],
+) -> float | None:
+    try:
+        return resolve_taker_fee_bps(row, fee_model=fee_model)
+    except FeeResolutionError:
+        blocked_entries["BLOCK_FEE_UNRESOLVED"] = blocked_entries.get("BLOCK_FEE_UNRESOLVED", 0) + 1
+        return None
+
+
+def run_long_breakout_backtest(
+    rows: list[TradeXyzMarketRow],
+    *,
+    config: BreakoutConfig,
+) -> BacktestRunResult:
+    """Run a minimal SP500-style long-only breakout backtest.
+
+    Signal timing is deliberately conservative: bar ``i`` may generate a signal,
+    but the fill happens on row ``i+1``. This keeps the MVP free from same-bar
+    execution leakage.
+    """
+
+    symbol = config.symbol.upper()
+    filtered = sorted([row for row in rows if row.symbol == symbol], key=lambda row: row.ts)
+    portfolio = BacktestPortfolio(initial_cash=config.initial_cash)
+    orders: list[BacktestOrder] = []
+    fills: list[BacktestFill] = []
+    equity_snapshots: list[EquitySnapshot] = []
+    blocked_entries: dict[str, int] = {}
+    session_breakdown: dict[str, int] = {}
+    market_status_breakdown: dict[str, int] = {}
+    pending_entry = False
+    pending_exit = False
+    order_seq = 0
+
+    closes = [row.effective_close for row in filtered]
+    mark_oracle_basis_values: list[float] = []
+    for index, row in enumerate(filtered):
+        _count_key(session_breakdown, row.session_type)
+        _count_key(market_status_breakdown, row.market_status)
+        position = portfolio.position(symbol)
+
+        if position.qty > 0:
+            cashflow = funding_cashflow_usd(position_qty=position.qty, row=row)
+            portfolio.apply_funding(symbol, cashflow)
+
+        if pending_entry and position.qty == 0:
+            pending_entry = False
+            reasons = row.entry_block_reasons()
+            if reasons:
+                for reason in reasons:
+                    blocked_entries[reason] = blocked_entries.get(reason, 0) + 1
+            else:
+                fee_bps = _try_resolve_entry_fee(
+                    row, fee_model=config.fee_model, blocked_entries=blocked_entries
+                )
+                if fee_bps is not None:
+                    order_seq += 1
+                    order = BacktestOrder(
+                        order_id=f"bt-{order_seq}",
+                        ts=row.ts,
+                        symbol=symbol,
+                        side=OrderSide.BUY,
+                        qty=config.qty,
+                    )
+                    fill = create_market_fill(order=order, row=row, fee_bps=fee_bps)
+                    orders.append(order)
+                    fills.append(fill)
+                    portfolio.apply_fill(fill)
+
+        if pending_exit and position.qty > 0:
+            pending_exit = False
+            fee_bps = resolve_taker_fee_bps(row, fee_model=config.fee_model)
+            order_seq += 1
+            order = BacktestOrder(
+                order_id=f"bt-{order_seq}",
+                ts=row.ts,
+                symbol=symbol,
+                side=OrderSide.SELL,
+                qty=position.qty,
+                reduce_only=True,
+            )
+            fill = create_market_fill(order=order, row=row, fee_bps=fee_bps)
+            orders.append(order)
+            fills.append(fill)
+            portfolio.apply_fill(fill)
+
+        snapshot = _snapshot(row=row, portfolio=portfolio, symbol=symbol)
+        equity_snapshots.append(snapshot)
+        if snapshot.mark_oracle_basis_bps is not None:
+            mark_oracle_basis_values.append(snapshot.mark_oracle_basis_bps)
+
+        current_close = closes[index]
+        if current_close is None:
+            continue
+        # Generate signals for the *next* row only.
+        position = portfolio.position(symbol)
+        if position.qty == 0 and index >= config.entry_lookback:
+            prior = [value for value in closes[index - config.entry_lookback : index] if value]
+            if len(prior) == config.entry_lookback and current_close > max(prior):
+                pending_entry = True
+        elif position.qty > 0 and index >= config.exit_lookback:
+            prior = [value for value in closes[index - config.exit_lookback : index] if value]
+            if len(prior) == config.exit_lookback and current_close < min(prior):
+                pending_exit = True
+
+    equity_curve = [snapshot.equity for snapshot in equity_snapshots]
+    metrics = summarize_metrics(
+        initial_cash=config.initial_cash,
+        equity_curve=equity_curve,
+        closed_trade_pnls=portfolio.closed_trade_pnls,
+        fee_impact_usd=portfolio.fees_paid,
+        funding_impact_usd=portfolio.funding_pnl,
+        mark_oracle_basis_bps=mark_oracle_basis_values,
+    )
+    return BacktestRunResult(
+        orders=orders,
+        fills=fills,
+        equity_curve=equity_curve,
+        equity_snapshots=equity_snapshots,
+        blocked_entries=blocked_entries,
+        session_breakdown=session_breakdown,
+        market_status_breakdown=market_status_breakdown,
+        metrics=metrics,
+    )
