+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+import pytest
+
+from sis.backtest.engine.fill import BacktestFill
+from sis.backtest.engine.order import OrderSide
+from sis.backtest.engine.portfolio import BacktestPortfolio
+
+
+def _fill(side: OrderSide, price: float, fee: float, qty: float = 1.0) -> BacktestFill:
+    return BacktestFill(
+        fill_id=f"fill-{side.value}-{price}",
+        order_id=f"order-{side.value}-{price}",
+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc),
+        symbol="SP500",
+        side=side,
+        qty=qty,
+        fill_price=price,
+        fee_usd=fee,
+        fee_bps=9.0,
+    )
+
+
+def test_portfolio_long_entry_and_exit_accounting() -> None:
+    portfolio = BacktestPortfolio(initial_cash=10_000)
+
+    entry = portfolio.apply_fill(_fill(OrderSide.BUY, 100.0, 0.09))
+    assert entry.qty == 1.0
+    assert entry.avg_price == 100.0
+    assert entry.realized_pnl == 0.0
+    assert portfolio.cash == pytest.approx(9899.91)
+
+    exit_position = portfolio.apply_fill(_fill(OrderSide.SELL, 110.0, 0.099))
+    assert exit_position.qty == 0.0
+    assert exit_position.avg_price == 0.0
+    assert exit_position.realized_pnl == pytest.approx(9.811)
+    assert portfolio.cash == pytest.approx(10009.811)
+    assert portfolio.equity({"SP500": 110.0}) == pytest.approx(10009.811)
+    assert portfolio.fees_paid == pytest.approx(0.189)
+
+
+def test_portfolio_rejects_sell_above_position() -> None:
+    portfolio = BacktestPortfolio(initial_cash=10_000)
+    with pytest.raises(ValueError):
+        portfolio.apply_fill(_fill(OrderSide.SELL, 110.0, 0.099))
