diff --git a/src/sis/backtest/trade_xyz/cost_model.py b/src/sis/backtest/trade_xyz/cost_model.py
new file mode 100644
index 0000000..ae7e89e
--- /dev/null
+++ b/src/sis/backtest/trade_xyz/cost_model.py
@@ -0,0 +1,79 @@
+from __future__ import annotations
+
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+class FeeResolutionError(ValueError):
+    pass
+
+
+def load_fee_model(path: Path) -> dict[str, Any]:
+    if not path.exists():
+        return {}
+    payload = yaml.safe_load(path.read_text(encoding="utf-8"))
+    return payload if isinstance(payload, dict) else {}
+
+
+def _trade_xyz_fee_config(fee_model: dict[str, Any]) -> dict[str, Any]:
+    root = fee_model.get("fee_model")
+    if not isinstance(root, dict):
+        return {}
+    config = root.get("trade_xyz")
+    return config if isinstance(config, dict) else {}
+
+
+def _fallback_fee_bps(config: dict[str, Any], fee_mode: str | None) -> float | None:
+    if not fee_mode:
+        return None
+    fallback = config.get("fallback")
+    if not isinstance(fallback, dict):
+        return None
+    entry = fallback.get(fee_mode)
+    if not isinstance(entry, dict):
+        return None
+    value = entry.get("taker_bps")
+    return float(value) if isinstance(value, int | float) else None
+
+
+def _classified_fee_mode(config: dict[str, Any], symbol: str) -> str | None:
+    classification = config.get("classification")
+    if not isinstance(classification, dict):
+        return None
+    mode = classification.get(symbol.upper())
+    return mode if isinstance(mode, str) and mode else None
+
+
+def resolve_taker_fee_bps(
+    row: TradeXyzMarketRow,
+    *,
+    fee_model: dict[str, Any] | None = None,
+) -> float:
+    """Resolve taker fee bps without hardcoding a universal fee.
+
+    Priority:
+    1. Resolved fee on the market row.
+    2. Row fee_mode fallback from config.
+    3. Symbol classification fallback from config.
+    Unknown fee remains a hard block.
+    """
+
+    if row.taker_fee_bps is not None and row.taker_fee_bps >= 0:
+        return row.taker_fee_bps
+
+    config = _trade_xyz_fee_config(fee_model or {})
+    fee_mode = row.fee_mode if row.fee_mode not in {None, "", "unknown"} else None
+    resolved = _fallback_fee_bps(config, fee_mode)
+    if resolved is not None:
+        return resolved
+
+    classified = _classified_fee_mode(config, row.symbol)
+    resolved = _fallback_fee_bps(config, classified)
+    if resolved is not None:
+        return resolved
+
+    raise FeeResolutionError(f"Cannot resolve taker fee for {row.symbol} fee_mode={row.fee_mode!r}")
diff --git a/src/sis/backtest/trade_xyz/funding.py b/src/sis/backtest/trade_xyz/funding.py
new file mode 100644
index 0000000..a1748ce
--- /dev/null
+++ b/src/sis/backtest/trade_xyz/funding.py
@@ -0,0 +1,27 @@
+from __future__ import annotations
+
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+class FundingModelError(ValueError):
+    pass
+
+
+def funding_cashflow_usd(*, position_qty: float, row: TradeXyzMarketRow) -> float:
+    """Return funding cashflow for a long position on a Trade[XYZ] row.
+
+    The model intentionally treats ``row.funding_rate`` as an already-resolved
+    funding event rate. It does not annualize, hour-scale, or infer intervals.
+
+    Sign convention:
+    - positive funding_rate: longs pay shorts, so long cashflow is negative.
+    - negative funding_rate: shorts pay longs, so long cashflow is positive.
+    """
+
+    if position_qty == 0 or row.funding_rate is None or row.funding_rate == 0:
+        return 0.0
+    if row.oracle_price is None or row.oracle_price <= 0:
+        raise FundingModelError(
+            f"Cannot apply funding for {row.symbol} at {row.ts}: oracle_price is missing"
+        )
+    return -position_qty * row.oracle_price * row.funding_rate
diff --git a/src/sis/backtest/trade_xyz/schema.py b/src/sis/backtest/trade_xyz/schema.py
new file mode 100644
index 0000000..ba1c2ea
--- /dev/null
+++ b/src/sis/backtest/trade_xyz/schema.py
@@ -0,0 +1,180 @@
+from __future__ import annotations
+
+from datetime import datetime
+from pathlib import Path
+from typing import Any, cast
+
+import polars as pl
+from pydantic import BaseModel, ConfigDict, Field, field_validator
+
+
+class TradeXyzMarketRow(BaseModel):
+    """Minimal Trade[XYZ] market row used by the pure BT engine.
+
+    This schema accepts current normalized quote column names while keeping
+    future Trade[XYZ] mechanics explicit: mark/oracle/external price, fee mode,
+    discovery bounds, OI cap and tradability gates.
+    """
+
+    model_config = ConfigDict(frozen=True)
+
+    ts: datetime
+    symbol: str
+    close: float | None = None
+    volume: float | None = None
+    mid_price: float | None = None
+    mark_price: float | None = None
+    oracle_price: float | None = None
+    external_price: float | None = None
+    index_price: float | None = None
+    exec_buy_price: float | None = None
+    exec_sell_price: float | None = None
+    best_bid: float | None = None
+    best_ask: float | None = None
+    bid_price: float | None = None
+    ask_price: float | None = None
+    spread_bps: float | None = None
+    funding_rate: float | None = None
+    funding_interval_minutes: int | None = None
+    taker_fee_bps: float | None = None
+    maker_fee_bps: float | None = None
+    fee_mode: str | None = None
+    session_type: str | None = None
+    market_status: str | None = None
+    discovery_bound_bps: float | None = None
+    open_interest_usd: float | None = None
+    oi_cap_usd: float | None = None
+    oi_cap_usage: float | None = None
+    is_tradable: bool = True
+    block_reasons: list[str] = Field(default_factory=list)
+    source_confidence: float | None = None
+    venue_quality_score: float | None = None
+
+    @field_validator("symbol")
+    @classmethod
+    def _normalize_symbol(cls, value: str) -> str:
+        normalized = value.strip().upper()
+        if not normalized:
+            raise ValueError("symbol must be non-empty")
+        return normalized
+
+    @field_validator("block_reasons", mode="before")
+    @classmethod
+    def _normalize_block_reasons(cls, value: object) -> list[str]:
+        if value is None:
+            return []
+        if isinstance(value, list):
+            return [str(item) for item in value if str(item)]
+        if isinstance(value, tuple):
+            return [str(item) for item in value if str(item)]
+        if isinstance(value, str):
+            stripped = value.strip()
+            return [stripped] if stripped else []
+        return [str(value)]
+
+    @classmethod
+    def from_mapping(cls, row: dict[str, Any]) -> "TradeXyzMarketRow":
+        raw_ts = row.get("ts") or row.get("ts_client")
+        if raw_ts is None:
+            raise ValueError("market row missing ts/ts_client")
+        ts = cast(datetime | str | int | float, raw_ts)
+        symbol = row.get("symbol") or row.get("canonical_symbol") or row.get("coin")
+        if symbol is None:
+            raise ValueError("market row missing symbol/canonical_symbol")
+        external = row.get("external_price")
+        if external is None:
+            external = row.get("index_price")
+        return cls(
+            ts=ts,
+            symbol=str(symbol).removeprefix("xyz:"),
+            close=row.get("close"),
+            volume=row.get("volume") or row.get("day_notional_volume"),
+            mid_price=row.get("mid_price"),
+            mark_price=row.get("mark_price"),
+            oracle_price=row.get("oracle_price"),
+            external_price=external,
+            index_price=row.get("index_price"),
+            exec_buy_price=row.get("exec_buy_price"),
+            exec_sell_price=row.get("exec_sell_price"),
+            best_bid=row.get("best_bid"),
+            best_ask=row.get("best_ask"),
+            bid_price=row.get("bid_price"),
+            ask_price=row.get("ask_price"),
+            spread_bps=row.get("spread_bps"),
+            funding_rate=row.get("funding_rate"),
+            funding_interval_minutes=row.get("funding_interval_minutes"),
+            taker_fee_bps=row.get("taker_fee_bps"),
+            maker_fee_bps=row.get("maker_fee_bps"),
+            fee_mode=row.get("fee_mode"),
+            session_type=row.get("session_type"),
+            market_status=row.get("market_status"),
+            discovery_bound_bps=row.get("discovery_bound_bps"),
+            open_interest_usd=row.get("open_interest_usd"),
+            oi_cap_usd=row.get("oi_cap_usd"),
+            oi_cap_usage=row.get("oi_cap_usage"),
+            is_tradable=bool(row.get("is_tradable", True)),
+            block_reasons=row.get("block_reasons"),
+            source_confidence=row.get("source_confidence"),
+            venue_quality_score=row.get("venue_quality_score"),
+        )
+
+    @property
+    def effective_close(self) -> float | None:
+        for value in (
+            self.close,
+            self.mid_price,
+            self.mark_price,
+            self.oracle_price,
+            self.index_price,
+        ):
+            if value is not None and value > 0:
+                return value
+        return None
+
+    @property
+    def computed_oi_cap_usage(self) -> float | None:
+        if self.oi_cap_usage is not None:
+            return self.oi_cap_usage
+        if self.open_interest_usd is None or self.oi_cap_usd in {None, 0}:
+            return None
+        return self.open_interest_usd / self.oi_cap_usd
+
+    def entry_block_reasons(
+        self,
+        *,
+        discovery_bound_buffer_ratio: float = 0.95,
+        oi_cap_buffer_ratio: float = 0.95,
+    ) -> list[str]:
+        reasons: list[str] = []
+        if not self.is_tradable:
+            reasons.append("BLOCK_NOT_TRADABLE")
+        reasons.extend(self.block_reasons)
+
+        reference = self.external_price or self.oracle_price or self.index_price
+        if (
+            self.discovery_bound_bps is not None
+            and self.discovery_bound_bps > 0
+            and self.mark_price is not None
+            and reference is not None
+            and reference > 0
+        ):
+            distance_bps = abs(self.mark_price / reference - 1.0) * 10_000
+            if distance_bps >= self.discovery_bound_bps * discovery_bound_buffer_ratio:
+                reasons.append("BLOCK_DISCOVERY_BOUND_NEAR")
+
+        oi_usage = self.computed_oi_cap_usage
+        if oi_usage is not None and oi_usage >= oi_cap_buffer_ratio:
+            reasons.append("BLOCK_OI_CAP_NEAR")
+
+        return list(dict.fromkeys(reasons))
+
+
+def load_market_rows_from_parquet(
+    path: Path, *, symbol: str | None = None
+) -> list[TradeXyzMarketRow]:
+    frame = pl.read_parquet(path)
+    if symbol is not None:
+        wanted = symbol.strip().upper()
+        column = "canonical_symbol" if "canonical_symbol" in frame.columns else "symbol"
+        frame = frame.filter(pl.col(column).str.to_uppercase() == wanted)
+    return [TradeXyzMarketRow.from_mapping(row) for row in frame.to_dicts()]
