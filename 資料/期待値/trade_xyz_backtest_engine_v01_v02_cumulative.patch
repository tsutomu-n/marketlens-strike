+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+
+from sis.backtest.engine.runner import BreakoutConfig, run_long_breakout_backtest
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+def _row(index: int, close: float, *, exec_buy_price: float | None = None) -> TradeXyzMarketRow:
+    return TradeXyzMarketRow(
+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc) + timedelta(hours=index),
+        symbol="SP500",
+        close=close,
+        mid_price=close,
+        exec_buy_price=exec_buy_price if exec_buy_price is not None else close + 0.1,
+        exec_sell_price=close - 0.1,
+        taker_fee_bps=9.0,
+        fee_mode="standard",
+        is_tradable=True,
+    )
+
+
+def test_breakout_entry_fills_on_next_row_not_signal_row() -> None:
+    closes = [100.0 + i * 0.1 for i in range(20)]
+    rows = [_row(i, close) for i, close in enumerate(closes)]
+    # Signal row: breakout close, but its executable price must not be used.
+    rows.append(_row(20, 105.0, exec_buy_price=999.0))
+    # Fill row.
+    rows.append(_row(21, 106.0, exec_buy_price=106.2))
+
+    result = run_long_breakout_backtest(
+        rows,
+        config=BreakoutConfig(symbol="SP500", entry_lookback=20, exit_lookback=10),
+    )
+
+    assert len(result.fills) == 1
+    assert result.fills[0].ts == rows[21].ts
+    assert result.fills[0].fill_price == 106.2
+    assert result.fills[0].fill_price_source == "exec_buy_price"
+
+
+def test_changing_future_after_fill_does_not_change_prior_fill() -> None:
+    base = [_row(i, 100.0 + i * 0.1) for i in range(20)]
+    base.extend([_row(20, 105.0, exec_buy_price=999.0), _row(21, 106.0, exec_buy_price=106.2)])
+    future_normal = [*base, _row(22, 107.0, exec_buy_price=107.2)]
+    future_changed = [*base, _row(22, 1000.0, exec_buy_price=1000.2)]
+
+    config = BreakoutConfig(symbol="SP500", entry_lookback=20, exit_lookback=10)
+    normal = run_long_breakout_backtest(future_normal, config=config)
+    changed = run_long_breakout_backtest(future_changed, config=config)
+
+    assert normal.fills[0].fill_price == changed.fills[0].fill_price == 106.2
