index 0000000..1a711d6
--- /dev/null
+++ b/src/sis/backtest/engine/metrics.py
@@ -0,0 +1,76 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+
+@dataclass(frozen=True)
+class BacktestMetricSummary:
+    total_return: float
+    final_equity: float
+    net_pnl_usd: float
+    max_drawdown: float
+    trade_count: int
+    win_rate: float | None
+    profit_factor: float | None
+    fee_impact_usd: float
+    funding_impact_usd: float = 0.0
+    worst_trade_pnl_usd: float | None = None
+    median_trade_pnl_usd: float | None = None
+    max_abs_mark_oracle_basis_bps: float | None = None
+
+
+def max_drawdown(values: list[float]) -> float:
+    if not values:
+        return 0.0
+    peak = values[0]
+    worst = 0.0
+    for value in values:
+        peak = max(peak, value)
+        if peak > 0:
+            worst = min(worst, value / peak - 1.0)
+    return worst
+
+
+def _median(values: list[float]) -> float | None:
+    if not values:
+        return None
+    ordered = sorted(values)
+    midpoint = len(ordered) // 2
+    if len(ordered) % 2:
+        return ordered[midpoint]
+    return (ordered[midpoint - 1] + ordered[midpoint]) / 2
+
+
+def summarize_metrics(
+    *,
+    initial_cash: float,
+    equity_curve: list[float],
+    closed_trade_pnls: list[float],
+    fee_impact_usd: float,
+    funding_impact_usd: float = 0.0,
+    mark_oracle_basis_bps: list[float] | None = None,
+) -> BacktestMetricSummary:
+    final_equity = equity_curve[-1] if equity_curve else initial_cash
+    wins = [value for value in closed_trade_pnls if value > 0]
+    losses = [value for value in closed_trade_pnls if value < 0]
+    win_rate = len(wins) / len(closed_trade_pnls) if closed_trade_pnls else None
+    profit_factor = None
+    if losses:
+        profit_factor = sum(wins) / abs(sum(losses)) if wins else 0.0
+    elif wins:
+        profit_factor = float("inf")
+    basis_values = [abs(value) for value in (mark_oracle_basis_bps or [])]
+    return BacktestMetricSummary(
+        total_return=final_equity / initial_cash - 1.0,
+        final_equity=final_equity,
+        net_pnl_usd=final_equity - initial_cash,
+        max_drawdown=max_drawdown(equity_curve),
+        trade_count=len(closed_trade_pnls),
+        win_rate=win_rate,
+        profit_factor=profit_factor,
+        fee_impact_usd=fee_impact_usd,
+        funding_impact_usd=funding_impact_usd,
+        worst_trade_pnl_usd=min(closed_trade_pnls) if closed_trade_pnls else None,
+        median_trade_pnl_usd=_median(closed_trade_pnls),
+        max_abs_mark_oracle_basis_bps=max(basis_values) if basis_values else None,
+    )
