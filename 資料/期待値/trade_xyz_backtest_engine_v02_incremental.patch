@@ -0,0 +1,256 @@
+from __future__ import annotations
+
+from dataclasses import asdict, is_dataclass
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+import hashlib
+import json
+import math
+
+import polars as pl
+
+from sis.backtest.engine.runner import BacktestRunResult, BreakoutConfig
+
+
+SCHEMA_VERSION = "trade_xyz_backtest_artifacts.v1"
+
+
+def _json_safe(value: Any) -> Any:
+    if is_dataclass(value):
+        return _json_safe(asdict(value))
+    if isinstance(value, dict):
+        return {str(key): _json_safe(item) for key, item in value.items()}
+    if isinstance(value, list | tuple):
+        return [_json_safe(item) for item in value]
+    if isinstance(value, datetime):
+        return value.isoformat()
+    if isinstance(value, float):
+        if math.isinf(value):
+            return "Infinity" if value > 0 else "-Infinity"
+        if math.isnan(value):
+            return None
+    return value
+
+
+def _write_json(path: Path, payload: dict[str, Any]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    path.write_text(
+        json.dumps(_json_safe(payload), ensure_ascii=False, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+
+
+def _hash_payload(payload: dict[str, Any]) -> str:
+    encoded = json.dumps(_json_safe(payload), ensure_ascii=False, sort_keys=True).encode("utf-8")
+    return hashlib.sha256(encoded).hexdigest()
+
+
+def _order_rows(result: BacktestRunResult) -> list[dict[str, Any]]:
+    rows: list[dict[str, Any]] = []
+    for order in result.orders:
+        rows.append(
+            {
+                "order_id": order.order_id,
+                "ts": order.ts,
+                "symbol": order.symbol,
+                "side": order.side.value,
+                "order_type": order.order_type.value,
+                "qty": order.qty,
+                "reduce_only": order.reduce_only,
+                "client_order_id": order.client_order_id,
+            }
+        )
+    return rows
+
+
+def _fill_rows(result: BacktestRunResult) -> list[dict[str, Any]]:
+    rows: list[dict[str, Any]] = []
+    for fill in result.fills:
+        rows.append(
+            {
+                "fill_id": fill.fill_id,
+                "order_id": fill.order_id,
+                "ts": fill.ts,
+                "symbol": fill.symbol,
+                "side": fill.side.value,
+                "qty": fill.qty,
+                "fill_price": fill.fill_price,
+                "notional_usd": fill.notional_usd,
+                "fee_usd": fill.fee_usd,
+                "fee_bps": fill.fee_bps,
+                "slippage_bps": fill.slippage_bps,
+                "liquidity_flag": fill.liquidity_flag,
+                "fill_price_source": fill.fill_price_source,
+                "client_order_id": fill.client_order_id,
+            }
+        )
+    return rows
+
+
+def _equity_rows(result: BacktestRunResult) -> list[dict[str, Any]]:
+    return [_json_safe(snapshot) for snapshot in result.equity_snapshots]
+
+
+def _blocked_rows(result: BacktestRunResult) -> list[dict[str, Any]]:
+    return [
+        {"reason": reason, "count": count}
+        for reason, count in sorted(result.blocked_entries.items())
+    ]
+
+
+def _write_parquet(path: Path, rows: list[dict[str, Any]]) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    pl.DataFrame(rows).write_parquet(path)
+
+
+def _render_report(
+    *,
+    run_id: str,
+    config: BreakoutConfig,
+    result: BacktestRunResult,
+    output_dir: Path,
+) -> str:
+    metrics = result.metrics
+    return "\n".join(
+        [
+            "# Trade[XYZ] Pure Backtest Report",
+            "",
+            f"- run_id: `{run_id}`",
+            f"- symbol: `{config.symbol.upper()}`",
+            "- strategy: `long_breakout_v0`",
+            "- no_live_order: `true`",
+            "- wallet_used: `false`",
+            "- exchange_write_used: `false`",
+            "",
+            "## Metrics",
+            "",
+            f"- total_return: `{metrics.total_return:.6f}`",
+            f"- final_equity: `{metrics.final_equity:.6f}`",
+            f"- net_pnl_usd: `{metrics.net_pnl_usd:.6f}`",
+            f"- max_drawdown: `{metrics.max_drawdown:.6f}`",
+            f"- trade_count: `{metrics.trade_count}`",
+            f"- win_rate: `{metrics.win_rate}`",
+            f"- profit_factor: `{metrics.profit_factor}`",
+            f"- fee_impact_usd: `{metrics.fee_impact_usd:.6f}`",
+            f"- funding_impact_usd: `{metrics.funding_impact_usd:.6f}`",
+            f"- max_abs_mark_oracle_basis_bps: `{metrics.max_abs_mark_oracle_basis_bps}`",
+            "",
+            "## Entry Blocks",
+            "",
+            *(f"- {reason}: {count}" for reason, count in sorted(result.blocked_entries.items())),
+            "",
+            "## Session Breakdown",
+            "",
+            *(f"- {key}: {count}" for key, count in sorted(result.session_breakdown.items())),
+            "",
+            "## Artifacts",
+            "",
+            f"- metrics: `{(output_dir / 'metrics.json').as_posix()}`",
+            f"- fills: `{(output_dir / 'fills.parquet').as_posix()}`",
+            f"- equity_curve: `{(output_dir / 'equity_curve.parquet').as_posix()}`",
+            "",
+        ]
+    )
+
+
+def write_backtest_artifacts(
+    *,
+    result: BacktestRunResult,
+    config: BreakoutConfig,
+    output_dir: Path,
+    input_path: Path | None = None,
+    fee_model_path: Path | None = None,
+    run_id: str | None = None,
+) -> dict[str, Path]:
+    output_dir.mkdir(parents=True, exist_ok=True)
+    resolved_run_id = (
+        run_id
+        or f"trade-xyz-{config.symbol.upper()}-{datetime.now(timezone.utc).strftime('%Y%m%dT%H%M%SZ')}"
+    )
+    config_payload = {
+        "schema_version": SCHEMA_VERSION,
+        "strategy_id": "long_breakout_v0",
+        "symbol": config.symbol.upper(),
+        "entry_lookback": config.entry_lookback,
+        "exit_lookback": config.exit_lookback,
+        "qty": config.qty,
+        "initial_cash": config.initial_cash,
+        "fee_model_path": fee_model_path.as_posix() if fee_model_path else None,
+        "funding_policy": "raw_rate_per_event_using_oracle_price",
+        "fill_model": "market_like_taker_next_row",
+    }
+    config_hash = _hash_payload(config_payload)
+    run_payload = {
+        "schema_version": SCHEMA_VERSION,
+        "run_id": resolved_run_id,
+        "created_at": datetime.now(timezone.utc).isoformat(),
+        "strategy_id": "long_breakout_v0",
+        "symbol": config.symbol.upper(),
+        "input_data_ref": input_path.as_posix() if input_path else None,
+        "config_hash": config_hash,
+        "fee_model_ref": fee_model_path.as_posix() if fee_model_path else None,
+        "no_live_order": True,
+        "wallet_used": False,
+        "exchange_write_used": False,
+    }
+    metrics_payload = {
+        "schema_version": SCHEMA_VERSION,
+        "run_id": resolved_run_id,
+        "metrics": asdict(result.metrics),
+        "blocked_reason_counts": result.blocked_entries,
+        "session_breakdown": result.session_breakdown,
+        "market_status_breakdown": result.market_status_breakdown,
+    }
+    paths = {
+        "backtest_run": output_dir / "backtest_run.json",
+        "config_snapshot": output_dir / "config.snapshot.json",
+        "config_hash": output_dir / "config_hash.txt",
+        "orders": output_dir / "orders.parquet",
+        "fills": output_dir / "fills.parquet",
+        "equity_curve": output_dir / "equity_curve.parquet",
+        "blocked_entries": output_dir / "blocked_entries.parquet",
+        "metrics": output_dir / "metrics.json",
+        "candidate_result": output_dir / "candidate_result.json",
+        "data_manifest": output_dir / "data_manifest.json",
+        "report": output_dir / "backtest_report.md",
+    }
+
+    _write_json(paths["backtest_run"], run_payload)
+    _write_json(paths["config_snapshot"], config_payload)
+    paths["config_hash"].write_text(config_hash + "\n", encoding="utf-8")
+    _write_parquet(paths["orders"], _order_rows(result))
+    _write_parquet(paths["fills"], _fill_rows(result))
+    _write_parquet(paths["equity_curve"], _equity_rows(result))
+    _write_parquet(paths["blocked_entries"], _blocked_rows(result))
+    _write_json(paths["metrics"], metrics_payload)
+    _write_json(
+        paths["candidate_result"],
+        {
+            "schema_version": SCHEMA_VERSION,
+            "run_id": resolved_run_id,
+            "candidate_status": "research_only",
+            "paper_candidate": result.metrics.trade_count > 0,
+            "no_live_order": True,
+            "wallet_used": False,
+            "exchange_write_used": False,
+            "metrics_ref": paths["metrics"].as_posix(),
+        },
+    )
+    _write_json(
+        paths["data_manifest"],
+        {
+            "schema_version": SCHEMA_VERSION,
+            "run_id": resolved_run_id,
+            "input_data_ref": input_path.as_posix() if input_path else None,
+            "row_count": len(result.equity_snapshots),
+            "order_count": len(result.orders),
+            "fill_count": len(result.fills),
+            "artifact_files": {key: path.as_posix() for key, path in paths.items()},
+        },
+    )
+    paths["report"].write_text(
+        _render_report(run_id=resolved_run_id, config=config, result=result, output_dir=output_dir),
+        encoding="utf-8",
+    )
+    return paths
