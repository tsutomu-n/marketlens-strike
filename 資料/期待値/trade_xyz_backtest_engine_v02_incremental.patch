+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+import json
+
+import polars as pl
+from typer.testing import CliRunner
+
+from sis.cli import app
+
+runner = CliRunner()
+
+
+def _quote_row(index: int, close: float, *, funding_rate: float | None = None) -> dict:
+    ts = datetime(2026, 5, 31, tzinfo=timezone.utc) + timedelta(hours=index)
+    return {
+        "ts_client": ts.isoformat(),
+        "canonical_symbol": "SP500",
+        "close": close,
+        "mid_price": close,
+        "mark_price": close + 0.1,
+        "oracle_price": close,
+        "index_price": close,
+        "exec_buy_price": close + 0.2,
+        "exec_sell_price": close - 0.2,
+        "taker_fee_bps": 9.0,
+        "maker_fee_bps": 3.0,
+        "fee_mode": "standard",
+        "session_type": "cash",
+        "market_status": "open",
+        "funding_rate": funding_rate,
+        "is_tradable": True,
+        "block_reasons": [],
+    }
+
+
+def test_backtest_trade_xyz_cli_writes_artifacts(tmp_path) -> None:
+    input_path = tmp_path / "quotes.parquet"
+    output_dir = tmp_path / "run"
+    rows = [
+        _quote_row(0, 100),
+        _quote_row(1, 101),
+        _quote_row(2, 103),
+        _quote_row(3, 104, funding_rate=0.001),
+        _quote_row(4, 102, funding_rate=0.001),
+        _quote_row(5, 99, funding_rate=0.001),
+        _quote_row(6, 98),
+    ]
+    pl.DataFrame(rows).write_parquet(input_path)
+
+    result = runner.invoke(
+        app,
+        [
+            "backtest-trade-xyz",
+            "--input-path",
+            str(input_path),
+            "--out",
+            str(output_dir),
+            "--symbol",
+            "SP500",
+            "--entry-lookback",
+            "2",
+            "--exit-lookback",
+            "2",
+            "--initial-cash",
+            "3000",
+        ],
+    )
+
+    assert result.exit_code == 0, result.stdout
+    assert "status=ok" in result.stdout
+    assert "metrics_path=" in result.stdout
+    assert (output_dir / "metrics.json").exists()
+    assert (output_dir / "fills.parquet").exists()
+    metrics = json.loads((output_dir / "metrics.json").read_text(encoding="utf-8"))
+    assert metrics["metrics"]["trade_count"] == 1
+
+
+def test_backtest_trade_xyz_cli_rejects_missing_input(tmp_path) -> None:
+    result = runner.invoke(
+        app,
+        [
+            "backtest-trade-xyz",
+            "--input-path",
+            str(tmp_path / "missing.parquet"),
+        ],
+    )
+
+    assert result.exit_code == 2
+    assert "input parquet not found" in result.stdout
