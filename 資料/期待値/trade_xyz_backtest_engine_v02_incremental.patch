+from __future__ import annotations
+
+from datetime import datetime, timezone
+
+import pytest
+
+from sis.backtest.engine.portfolio import BacktestPortfolio
+from sis.backtest.trade_xyz.funding import FundingModelError, funding_cashflow_usd
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+def _row(**kwargs) -> TradeXyzMarketRow:
+    return TradeXyzMarketRow(
+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc),
+        symbol="SP500",
+        **kwargs,
+    )
+
+
+def test_positive_funding_rate_is_cost_for_long() -> None:
+    row = _row(oracle_price=100.0, funding_rate=0.001)
+
+    assert funding_cashflow_usd(position_qty=2.0, row=row) == pytest.approx(-0.2)
+
+
+def test_negative_funding_rate_is_credit_for_long() -> None:
+    row = _row(oracle_price=100.0, funding_rate=-0.001)
+
+    assert funding_cashflow_usd(position_qty=2.0, row=row) == pytest.approx(0.2)
+
+
+def test_funding_requires_oracle_when_rate_present() -> None:
+    row = _row(funding_rate=0.001)
+
+    with pytest.raises(FundingModelError):
+        funding_cashflow_usd(position_qty=1.0, row=row)
+
+
+def test_portfolio_funding_cashflow_affects_cash_and_closed_pnl() -> None:
+    from sis.backtest.engine.fill import BacktestFill
+    from sis.backtest.engine.order import OrderSide
+
+    portfolio = BacktestPortfolio(initial_cash=1_000)
+    ts = datetime(2026, 5, 31, tzinfo=timezone.utc)
+    portfolio.apply_fill(
+        BacktestFill(
+            fill_id="f1",
+            order_id="o1",
+            ts=ts,
+            symbol="SP500",
+            side=OrderSide.BUY,
+            qty=1,
+            fill_price=100,
+            fee_usd=0.1,
+            fee_bps=10,
+        )
+    )
+    portfolio.apply_funding("SP500", -0.2)
+    portfolio.apply_fill(
+        BacktestFill(
+            fill_id="f2",
+            order_id="o2",
+            ts=ts,
+            symbol="SP500",
+            side=OrderSide.SELL,
+            qty=1,
+            fill_price=110,
+            fee_usd=0.1,
+            fee_bps=10,
+        )
+    )
+
+    assert portfolio.funding_pnl == pytest.approx(-0.2)
+    assert portfolio.closed_trade_pnls == [pytest.approx(9.6)]
+    assert portfolio.cash == pytest.approx(1009.6)
