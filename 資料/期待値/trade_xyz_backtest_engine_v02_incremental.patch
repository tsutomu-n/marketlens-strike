@@ -0,0 +1,105 @@
+from __future__ import annotations
+
+from datetime import datetime, timezone
+from pathlib import Path
+
+import typer
+
+from sis.backtest.engine.artifacts import write_backtest_artifacts
+from sis.backtest.engine.runner import BreakoutConfig, run_long_breakout_backtest
+from sis.backtest.trade_xyz.cost_model import load_fee_model
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow, load_market_rows_from_parquet
+from sis.settings import get_settings
+
+
+def _parse_datetime(value: str | None) -> datetime | None:
+    if not value:
+        return None
+    parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
+    if parsed.tzinfo is None:
+        parsed = parsed.replace(tzinfo=timezone.utc)
+    return parsed
+
+
+def _filter_rows(
+    rows: list[TradeXyzMarketRow], *, start: str | None, end: str | None
+) -> list[TradeXyzMarketRow]:
+    start_dt = _parse_datetime(start)
+    end_dt = _parse_datetime(end)
+    filtered = rows
+    if start_dt is not None:
+        filtered = [row for row in filtered if row.ts >= start_dt]
+    if end_dt is not None:
+        filtered = [row for row in filtered if row.ts <= end_dt]
+    return filtered
+
+
+def register_trade_xyz_backtest_commands(app: typer.Typer) -> None:
+    @app.command("backtest-trade-xyz")
+    def backtest_trade_xyz_cmd(
+        symbol: str = typer.Option("SP500", "--symbol", help="Trade[XYZ] canonical symbol."),
+        input_path: Path | None = typer.Option(
+            None,
+            "--input-path",
+            help="Normalized quote parquet path. Defaults to data/normalized/quotes.parquet.",
+        ),
+        output_dir: Path | None = typer.Option(
+            None,
+            "--out",
+            help="Backtest output directory. Defaults to data/backtests/<symbol>_breakout.",
+        ),
+        fee_model_path: Path | None = typer.Option(
+            None,
+            "--fee-model-path",
+            help="Trade[XYZ] fee model YAML. Defaults to configs/fee_model.trade_xyz.yaml.",
+        ),
+        start: str | None = typer.Option(None, "--from", help="Inclusive ISO-8601 start time."),
+        end: str | None = typer.Option(None, "--to", help="Inclusive ISO-8601 end time."),
+        entry_lookback: int = typer.Option(20, "--entry-lookback"),
+        exit_lookback: int = typer.Option(10, "--exit-lookback"),
+        qty: float = typer.Option(1.0, "--qty"),
+        initial_cash: float = typer.Option(3000.0, "--initial-cash"),
+    ) -> None:
+        settings = get_settings()
+        resolved_input = input_path or (settings.data_dir / "normalized/quotes.parquet")
+        resolved_output = output_dir or (
+            settings.data_dir / "backtests" / f"{symbol.upper()}_long_breakout_v0"
+        )
+        resolved_fee_model = fee_model_path or Path("configs/fee_model.trade_xyz.yaml")
+
+        if not resolved_input.exists():
+            typer.echo(f"input parquet not found: {resolved_input}")
+            raise typer.Exit(code=2)
+        rows = load_market_rows_from_parquet(resolved_input, symbol=symbol)
+        rows = _filter_rows(rows, start=start, end=end)
+        if not rows:
+            typer.echo(f"no rows found for symbol={symbol.upper()}")
+            raise typer.Exit(code=2)
+
+        fee_model = load_fee_model(resolved_fee_model)
+        config = BreakoutConfig(
+            symbol=symbol.upper(),
+            entry_lookback=entry_lookback,
+            exit_lookback=exit_lookback,
+            qty=qty,
+            initial_cash=initial_cash,
+            fee_model=fee_model,
+        )
+        result = run_long_breakout_backtest(rows, config=config)
+        paths = write_backtest_artifacts(
+            result=result,
+            config=config,
+            output_dir=resolved_output,
+            input_path=resolved_input,
+            fee_model_path=resolved_fee_model,
+        )
+
+        typer.echo("status=ok")
+        typer.echo(f"symbol={symbol.upper()}")
+        typer.echo(f"row_count={len(rows)}")
+        typer.echo(f"trade_count={result.metrics.trade_count}")
+        typer.echo(f"net_pnl_usd={result.metrics.net_pnl_usd:.6f}")
+        typer.echo(f"total_return={result.metrics.total_return:.6f}")
+        typer.echo(f"metrics_path={paths['metrics']}")
+        typer.echo(f"report_path={paths['report']}")
+        typer.echo(f"fills_path={paths['fills']}")
