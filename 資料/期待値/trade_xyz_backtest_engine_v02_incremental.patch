@@ -0,0 +1,60 @@
+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+import json
+
+import polars as pl
+
+from sis.backtest.engine.artifacts import write_backtest_artifacts
+from sis.backtest.engine.runner import BreakoutConfig, run_long_breakout_backtest
+from sis.backtest.trade_xyz.schema import TradeXyzMarketRow
+
+
+def _row(index: int, close: float, *, funding_rate: float | None = None) -> TradeXyzMarketRow:
+    return TradeXyzMarketRow(
+        ts=datetime(2026, 5, 31, tzinfo=timezone.utc) + timedelta(hours=index),
+        symbol="SP500",
+        close=close,
+        mid_price=close,
+        mark_price=close + 0.1,
+        oracle_price=close,
+        index_price=close,
+        exec_buy_price=close + 0.2,
+        exec_sell_price=close - 0.2,
+        taker_fee_bps=9.0,
+        fee_mode="standard",
+        session_type="cash",
+        market_status="open",
+        funding_rate=funding_rate,
+        is_tradable=True,
+    )
+
+
+def test_artifact_writer_outputs_json_and_parquet_contracts(tmp_path) -> None:
+    rows = [
+        _row(0, 100),
+        _row(1, 101),
+        _row(2, 103),
+        _row(3, 104, funding_rate=0.001),
+        _row(4, 102, funding_rate=0.001),
+        _row(5, 99, funding_rate=0.001),
+        _row(6, 98),
+    ]
+    config = BreakoutConfig(symbol="SP500", entry_lookback=2, exit_lookback=2, initial_cash=3000)
+    result = run_long_breakout_backtest(rows, config=config)
+
+    paths = write_backtest_artifacts(result=result, config=config, output_dir=tmp_path)
+
+    assert paths["metrics"].exists()
+    assert paths["fills"].exists()
+    assert paths["equity_curve"].exists()
+    assert paths["report"].exists()
+    metrics = json.loads(paths["metrics"].read_text(encoding="utf-8"))
+    assert metrics["schema_version"] == "trade_xyz_backtest_artifacts.v1"
+    assert metrics["metrics"]["funding_impact_usd"] < 0
+    assert metrics["session_breakdown"]["cash"] == len(rows)
+    fills = pl.read_parquet(paths["fills"])
+    assert fills.height == 2
+    equity = pl.read_parquet(paths["equity_curve"])
+    assert "mark_oracle_basis_bps" in equity.columns
+    assert "no_live_order: `true`" in paths["report"].read_text(encoding="utf-8")
